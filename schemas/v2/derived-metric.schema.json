{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qa.projectbluefin.io/schemas/v2/derived-metric.schema.json",
  "title": "Derived metric record",
  "description": "A single research-grade derived metric: value with explicit estimator, sample size, confidence interval, method, methodology link, and FMEA failure-mode catalog. Every derived record under docs/data/derived/ MUST conform to this schema.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "generator",
    "metrics"
  ],
  "properties": {
    "schema_version": { "const": "v2" },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when this derived record was produced."
    },
    "generator": {
      "type": "object",
      "required": ["notebook", "notebook_url", "inputs_sha256"],
      "properties": {
        "notebook": {
          "type": "string",
          "pattern": "^notebooks/[A-Za-z0-9_./-]+\\.ipynb$",
          "description": "Path of the notebook that produced this record."
        },
        "notebook_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://",
          "description": "Public URL of the rendered notebook HTML (docs/methods/*.html) so a reader can audit the methodology."
        },
        "workflow_run_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL of the .github/workflows/derive.yml run that produced this output, when available."
        },
        "commit_sha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "inputs_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA-256 over the concatenated, byte-sorted hashes of every raw input file consumed by the notebook. Two runs producing the same inputs_sha256 MUST produce the same metrics."
        },
        "library_versions": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Pinned versions of the statistical libraries used (e.g. statsmodels, scipy, lifelines, ruptures)."
        }
      }
    },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/metric" }
    }
  },
  "$defs": {
    "metric": {
      "type": "object",
      "required": [
        "id",
        "label",
        "value",
        "ci_lower",
        "ci_upper",
        "n",
        "unit",
        "method",
        "method_citation",
        "window",
        "confidence",
        "state",
        "failure_modes",
        "evidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+(\\.[a-z0-9_-]+)*$",
          "description": "Stable machine ID. Dot-separated path is allowed for keying by (metric, variant, branch, suite)."
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": ["number", "null"],
          "description": "Point estimate. Null only when n==0 (declared insufficient data); UI must render as 'not_attested' state."
        },
        "ci_lower": { "type": ["number", "null"] },
        "ci_upper": { "type": ["number", "null"] },
        "ci_level": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.95
        },
        "n": {
          "type": "integer",
          "minimum": 0,
          "description": "Sample size. n==0 is allowed but value/ci_lower/ci_upper MUST then be null and state MUST be 'unknown' or 'not_attested'."
        },
        "unit": {
          "type": "string",
          "enum": ["proportion", "percent", "count", "seconds", "hours", "ratio", "bool", "score"]
        },
        "method": {
          "type": "string",
          "enum": [
            "wilson_score_95",
            "wilson_score_99",
            "clopper_pearson_95",
            "bayesian_online_changepoint",
            "cusum",
            "kaplan_meier",
            "fisher_exact",
            "mann_kendall",
            "mutual_information",
            "ssim",
            "pixelmatch",
            "mad_outlier",
            "reproducible_rebuild_match",
            "slsa_attestation_walk",
            "raw_proportion"
          ],
          "description": "Named statistical estimator. Adding a value requires updating tests/unit/test_derived_contract.py in the same PR."
        },
        "method_citation": {
          "type": "string",
          "minLength": 1,
          "description": "Free-form citation (paper or canonical reference URL)."
        },
        "window": {
          "type": "object",
          "required": ["type", "size"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["rolling_runs", "rolling_hours", "rolling_days", "since_epoch"]
            },
            "size": { "type": ["integer", "number"], "minimum": 0 },
            "audience": {
              "type": ["string", "null"],
              "enum": ["contributor", "user", "downstream", null],
              "description": "Trust-window audience hint (24h/7d/30d)."
            }
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Self-declared confidence. Estimates (derived from medians, narrative defaults) use 'low' and MUST NOT be elevated to hero tiles."
        },
        "state": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "unknown",
            "partial",
            "degraded",
            "not_attested",
            "not_published",
            "blocked",
            "published"
          ],
          "description": "Harmonized with tests/unit/test_factory_dashboard_contract.py ALLOWED_HONEST_STATES + the snapshot enum. Pills in the UI MUST switch on this exact set."
        },
        "age_minutes": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "context": {
          "type": "object",
          "description": "Per-metric breakdown axes. By convention: variant, branch, suite, scenario_slug.",
          "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
        },
        "formula": {
          "type": "string",
          "minLength": 1,
          "description": "Plain-English formula. e.g., 'p̂ = passes/n; CI = Wilson score interval at 95%'."
        },
        "numerator": { "type": ["number", "null"] },
        "denominator": { "type": ["number", "null"] },
        "failure_modes": {
          "type": "array",
          "minItems": 1,
          "description": "FMEA: declared ways this number could be wrong. At least one entry required, even if all 'active': false.",
          "items": { "$ref": "#/$defs/failure_mode" }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "description": "Provenance: at least one https URL pointing at the underlying raw input or workflow run.",
          "items": { "$ref": "#/$defs/evidence_ref" }
        }
      }
    },
    "failure_mode": {
      "type": "object",
      "required": ["id", "description", "active"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "description": { "type": "string", "minLength": 1 },
        "active": { "type": "boolean" },
        "threshold": { "type": ["string", "null"] },
        "evidence_url": {
          "type": ["string", "null"],
          "format": "uri",
          "pattern": "^https://"
        }
      }
    },
    "evidence_ref": {
      "type": "object",
      "required": ["kind", "url"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["raw-input", "workflow-run", "build-log", "attestation", "screenshot", "collector-run", "commit", "release"]
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        },
        "path": {
          "type": ["string", "null"],
          "description": "Repo-relative path of the raw input file consumed, when applicable."
        },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^(sha256:)?[0-9a-f]{64}$"
        }
      }
    }
  }
}
