---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  pillText?: string;
  pillType?: string;
  statusValue?: string;
  open?: boolean;
  class?: string;
}

const { id, eyebrow, title, pillText, pillType, statusValue, open = false, class: className = "" } = Astro.props;
---
<details id={id} class:list={["detail-card", className]} open={open}>
  <summary>
    <div>
      {eyebrow && <p class="detail-card__eyebrow">{eyebrow}</p>}
      <h3>{title}</h3>
    </div>
    <div class="detail-card__summary">
      {pillText && (
        <span class:list={["pill", pillType ? `pill--${pillType}` : `pill--${pillText.toLowerCase()}`]}>
          {pillText}
        </span>
      )}
      {statusValue && <strong>{statusValue}</strong>}
    </div>
  </summary>

  <div class="detail-card__body">
    <slot />
  </div>
</details>
