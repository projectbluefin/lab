---
import '../styles/site.css';

interface Props {
  title: string;
  description: string;
  current: 'overview' | 'upstream' | 'tests' | 'applications' | 'homebrew' | 'adoption' | 'userspace';
  includeDashboardAssets?: boolean;
}

const { title, description, current, includeDashboardAssets = false } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const navItems = [
  { id: 'upstream', label: 'Upstream', href: `${baseUrl}upstream/` },
  { id: 'tests', label: 'Tests', href: `${baseUrl}tests/` },
  { id: 'applications', label: 'Applications', href: `${baseUrl}applications/` },
  { id: 'homebrew', label: 'Homebrew', href: `${baseUrl}homebrew/` },
  { id: 'adoption', label: 'Adoption', href: `${baseUrl}adoption/` },
  { id: 'userspace', label: 'Userspace', href: `${baseUrl}userspace/` },
] as const;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <title>{title} · Project Bluefin Operating System Factory</title>
    {includeDashboardAssets && (
      <>
        <link rel="stylesheet" href={`${baseUrl}assets/factory-dashboard.css`} />
        <script is:inline src={`${baseUrl}assets/factory-dashboard.js`} defer data-cfasync="false"></script>
      </>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href={baseUrl}>
          <span class="site-brand__eyebrow">Project Bluefin</span>
          <span class="site-brand__title">Operating System Factory</span>
        </a>
        <nav class="site-nav" aria-label="Factory sections">
          {navItems.map((item) => (
            <a class:list={["site-nav__link", current === item.id && 'is-active']} href={item.href} aria-current={current === item.id ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main class="site-shell">
      <slot />
    </main>
  </body>
</html>
