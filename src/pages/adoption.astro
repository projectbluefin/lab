---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadAdoptionPageModel } from '../lib/adoption-page';
import { loadHomebrewPageModel } from '../lib/homebrew-page';
import { serializeJsonScript } from '../lib/json-script';
import { readFileSync } from 'node:fs';

const baseUrl = import.meta.env.BASE_URL;
const pageModel = loadAdoptionPageModel(`${process.cwd()}/docs/data/adoption-metrics.json`);
const homebrewModel = loadHomebrewPageModel(`${process.cwd()}/docs/data/homebrew-ecosystem.json`);
const countmeMigrated = JSON.parse(readFileSync(`${process.cwd()}/docs/data/adoption-countme-migrated.json`, 'utf8'));

const { dataset, summaryMetrics, trustCards, rows, laneStats, chartData } = pageModel;

const {
  dataset: hbDataset,
  summaryMetrics: hbSummaryMetrics,
  taps: hbTaps,
  rows: hbRows,
  availableRows: hbAvailableRows,
  unavailableRows: hbUnavailableRows,
  packageLeaderboard: hbPackageLeaderboard,
  tapDensityRows: hbTapDensityRows,
  tapDensitySummary: hbTapDensitySummary,
  chartData: hbChartData,
} = homebrewModel;

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : '—';

const fmt = (n: number) =>
  n >= 1_000_000
    ? (n / 1_000_000).toFixed(1) + 'M'
    : n >= 1_000
      ? (n / 1_000).toFixed(1) + 'K'
      : n.toLocaleString();

const extendedChartData = {
  lanesCoverage: chartData.lanesCoverage,
  trustCoverage: chartData.trustCoverage,
  countmeTrend: dataset.countme_trend,
  countmeMigrated: countmeMigrated,
  quayTrend: dataset.quay_trend,
  doraComparison: dataset.dora_comparison,
  osVersion: dataset.os_version,
  openssfScorecard: dataset.openssf_scorecard,
  ociBestPractices: dataset.oci_best_practices,
  homebrew: hbChartData,
};

const serializedPageData = serializeJsonScript(extendedChartData);

const unavailableTrustCards = trustCards.filter((c) => c.state === 'unavailable');
const transplantedCountmeRow = rows.find((r) => r.countme_active_devices !== null) ?? null;
---

<SiteLayout
  title="Adoption & Ecosystem Metrics"
  description="Executive-readable adoption metrics, supply-chain best practices, and security posture scorecards for the Project Bluefin Operating System Factory."
  current="adoption"
>
  <style>
    /* Premium Dashboard Styles */
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .dashboard-header .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .dashboard-header .meta-bar a {
      color: #38bdf8;
      text-decoration: none;
    }
    .dashboard-header .meta-bar a:hover {
      text-decoration: underline;
    }

    .explainer-box {
      background: rgba(30, 41, 59, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
      color: #94a3b8;
      line-height: 1.6;
      font-size: 0.95rem;
    }
    .explainer-box strong {
      color: #f1f5f9;
    }

    /* KPI Scorecards Grid */
    .kpi-section-title {
      font-size: 1.15rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #3b82f6;
      padding-left: 10px;
    }
    .kpi-card--brew {
      background: linear-gradient(135deg, rgba(251, 146, 60, 0.15) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(251, 146, 60, 0.25);
    }
    .kpi-card--brew:hover { border-color: rgba(251, 146, 60, 0.45); }
    .kpi-card--ok {
      background: linear-gradient(135deg, rgba(34, 197, 94, 0.12) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(34, 197, 94, 0.2);
    }
    .badge-ok      { color: #4ade80; }
    .badge-gap     { color: #94a3b8; }
    .badge-warning { color: #fbbf24; }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-weight: 600;
      font-size: 0.82rem;
    }
    .panel-eyebrow {
      font-size: 0.78rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 0.35rem;
    }
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .kpi-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 145px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .kpi-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    .kpi-card--total {
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.15) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(99, 102, 241, 0.25);
    }
    .kpi-card--total:hover {
      border-color: rgba(99, 102, 241, 0.45);
    }
    .kpi-card__title {
      font-size: 0.8rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .kpi-card__value {
      font-size: 2rem;
      font-weight: 800;
      color: #f8fafc;
      letter-spacing: -0.04em;
      margin: 0.5rem 0 0.25rem 0;
      display: flex;
      align-items: baseline;
    }
    .kpi-card__trend {
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.125rem 0.35rem;
      border-radius: 999px;
      margin-left: 0.5rem;
    }
    .trend--up {
      background: rgba(34, 197, 94, 0.15);
      color: #4ade80;
    }
    .trend--down {
      background: rgba(239, 68, 68, 0.15);
      color: #f87171;
    }
    .trend--neutral {
      background: rgba(148, 163, 184, 0.15);
      color: #94a3b8;
    }
    .kpi-card__sparkline {
      width: 100%;
      height: 32px;
      margin-top: 0.5rem;
    }
    .kpi-card__sub {
      font-size: 0.72rem;
      color: #64748b;
    }

    /* Future Proofed OCI Best Practices Table */
    .fp-table-wrapper {
      overflow-x: auto;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      background: rgba(15, 23, 42, 0.4);
      margin-bottom: 2.5rem;
    }
    .fp-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }
    .fp-table th, .fp-table td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .fp-table th {
      color: #94a3b8;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .fp-table td {
      color: #e2e8f0;
      font-size: 0.9rem;
    }
    .fp-table tr:last-child td {
      border-bottom: 0;
    }
    .fp-table tr:hover td {
      background: rgba(255, 255, 255, 0.015);
    }
    .cell-image {
      font-weight: 600;
      color: #f1f5f9 !important;
    }
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-weight: 600;
      font-size: 0.82rem;
    }
    .badge-success { color: #4ade80; }
    .badge-danger { color: #f87171; }
    .badge-warning { color: #fbbf24; }
    .badge-muted { color: #64748b; }

    /* OpenSSF Scorecards */
    .sc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .sc-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.55) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 14px;
      padding: 1.15rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 115px;
      text-decoration: none;
      transition: all 0.25s ease;
    }
    .sc-card:hover {
      border-color: rgba(167, 139, 250, 0.4);
      transform: translateY(-2px);
    }
    .sc-card__name {
      font-family: monospace;
      font-size: 0.85rem;
      color: #cbd5e1;
      font-weight: 600;
    }
    .sc-card__score {
      font-size: 1.65rem;
      font-weight: 800;
      margin: 0.5rem 0;
    }
    .sc-card__date {
      font-size: 0.7rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    /* DORA Grid */
    .dora-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .dora-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.55) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 14px;
      padding: 1.15rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .dora-card__name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #f1f5f9;
    }
    .dora-card__level {
      font-size: 1.25rem;
      font-weight: 800;
    }
    .dora-card__stat {
      font-size: 0.8rem;
      color: #94a3b8;
    }

    /* Visual Layout Blocks */
    .dashboard-panel {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: var(--site-shadow);
      margin-bottom: 1.5rem;
    }
    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .panel-header h3 {
      font-size: 1rem;
      font-weight: 700;
      color: #cbd5e1;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0;
    }
    .btn-group {
      display: flex;
      background: rgba(15, 23, 42, 0.5);
      padding: 0.2rem;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .toggle-btn {
      background: transparent;
      border: none;
      color: #94a3b8;
      padding: 0.3rem 0.7rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.72rem;
      font-weight: 700;
      transition: all 0.2s;
    }
    .toggle-btn:hover {
      color: #f8fafc;
    }
    .toggle-btn.active {
      background: #3b82f6;
      color: #f8fafc;
    }
    .chart-box {
      width: 100%;
      height: 300px;
    }
    .chart-box-large {
      width: 100%;
      height: 380px;
    }
    .chart-box-16-9 {
      width: 100%;
      aspect-ratio: 16 / 9;
      min-height: 200px;
    }
    .chart-caption {
      font-size: 0.8rem;
      color: #64748b;
      margin-top: 0.5rem;
      text-align: center;
    }

    /* Legacy sections wrapper for compatibility */
    .factory-status-section {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      margin-top: 3.5rem;
      padding-top: 2rem;
    }

    /* Style resets and utilities */
    .verified-badge {
      color: #3b82f6;
      font-weight: bold;
      margin-left: 0.25rem;
    }
    .footnote {
      font-size: 0.8rem;
      color: #64748b;
      margin-top: 0.5rem;
    }
    .footnote a {
      color: #38bdf8;
      text-decoration: none;
    }
    .footnote a:hover {
      text-decoration: underline;
    }
  </style>

  <div class="dashboard-header">
    <h1>bootc Active Devices & Adoption</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(dataset._meta.generated_at)}</span>
      <span>Registry source: Quay.io / GHCR public API</span>
      <span>Countme source: <a href="https://github.com/ublue-os/countme">ublue-os/countme</a></span>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem; margin-top: 1rem;">
    <!-- Active Devices Trend -->
    <div class="dashboard-panel" style="margin-bottom: 0;">
      <div class="panel-header">
        <h3>Active Devices Trend</h3>
        <div class="btn-group" id="countme-range-btns">
          <button class="toggle-btn" data-range="30">30d</button>
          <button class="toggle-btn" data-range="90">90d</button>
          <button class="toggle-btn active" data-range="365">365d</button>
          <button class="toggle-btn" data-range="all">All</button>
        </div>
      </div>
      <div class="chart-box" id="countme-trend-chart" style="height: 320px;"></div>
    </div>

    <!-- Ecosystem Share Pie Chart -->
    <div class="dashboard-panel" style="margin-bottom: 0;">
      <div class="panel-header">
        <h3>Ecosystem Share</h3>
      </div>
      <div class="chart-box" id="ecosystem-pie-chart" style="height: 320px;"></div>
      <div class="footnote" style="margin-top: 1.25rem; color: #64748b; font-size: 0.82rem; line-height: 1.5; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 0.75rem;">
        Latest-week share of custom downstream images tracked via countme. Source: <a href={`${baseUrl}data/adoption-metrics.json`} style="color: #38bdf8; text-decoration: none;">adoption-metrics.json</a>.
      </div>
    </div>
  </div>

  <!-- Summary Grid for legacy test selector match (rendered hidden) -->
  <section class="summary-grid" aria-label="adoption-summary-metrics" style="display: none;">
    {summaryMetrics.map((metric) => (
      <article class="metric-card">
        <p class="metric-card__label">{metric.label}</p>
        <p class="metric-card__value">{metric.value}</p>
        <p class="metric-card__meta">
          <span>{metric.unit}</span>
          <a href={metric.source_url}>Evidence</a>
        </p>
      </article>
    ))}
  </section>

  <div class="dashboard-panel">
    <div class="panel-header">
      <h3>Image Pull Trend</h3>
      <div class="btn-group" id="quay-trend-range-btns">
        <button class="toggle-btn" data-range="30">30d</button>
        <button class="toggle-btn active" data-range="90">90d</button>
      </div>
    </div>
    <div class="chart-box" id="quay-trend"></div>
    <div class="chart-caption">
      Quay.io public registry pulls by day. Source: <a href={`${baseUrl}data/adoption-metrics.json`} style="color: #38bdf8; text-decoration: none;">adoption-metrics.json</a>.
    </div>
  </div>

  <!-- Project DORA Health Section -->
  <h2 class="kpi-section-title">Project DORA Health</h2>
  <div class="dashboard-panel" style="margin-bottom: 2.5rem;">
    <div class="panel-header">
      <h3>Deployment Frequency Trend</h3>
    </div>
    <div class="chart-box" id="dora-trend-chart" style="height: 320px;"></div>
    <div class="chart-caption">
      Monthly deployment-frequency index by project from docs/data/adoption-metrics.json. Higher is more frequent.
    </div>
  </div>

  <!-- Future Proofed Section -->
  <h2 class="kpi-section-title">Future Proofed</h2>
  <div class="explainer-box" style="margin-bottom: 1rem;">
    These checks measure OCI image build best practices adopted across the bootc ecosystem.
    Signing and SBOM rates are computed from CI workflow step detection over the last 30 days.
    zstd:chunked, chunking mode, and SLSA provenance are sourced from OCI image supply-chain snapshots.
  </div>
  <div class="fp-table-wrapper">
    <table class="fp-table">
      <thead>
        <tr>
          <th>Image</th>
          <th>Cosign Signing</th>
          <th>SBOM</th>
          <th>zstd:chunked</th>
          <th>chunked (chunka)</th>
          <th>SLSA</th>
        </tr>
      </thead>
      <tbody>
        {dataset.oci_best_practices?.map((item) => {
          const formatStatus = (val: string) => {
            const lower = val.toLowerCase();
            if (lower === 'yes' || lower === 'success' || lower === 'true' || lower.includes('yes')) {
              return <span class="status-badge badge-success">Yes</span>;
            }
            if (lower === 'no' || lower === 'danger' || lower === 'false' || lower.includes('no')) {
              return <span class="status-badge badge-danger">No</span>;
            }
            if (lower === 'warning') {
              return <span class="status-badge badge-warning">Warning</span>;
            }
            return <span class="status-badge badge-muted">{val}</span>;
          };
          return (
            <tr>
              <td class="cell-image">{item.image}</td>
              <td>{formatStatus(item.cosign)}</td>
              <td>{formatStatus(item.sbom)}</td>
              <td>{formatStatus(item.zstd)}</td>
              <td>{formatStatus(item.chunked)}</td>
              <td>{formatStatus(item.slsa)}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- OpenSSF Scorecard Section -->
  <h2 class="kpi-section-title">OpenSSF Scorecard</h2>
  {dataset.openssf_scorecard && dataset.openssf_scorecard.length > 0 ? (
    <div class="sc-grid">
      {dataset.openssf_scorecard.map((card) => {
        const uri = card.repo === 'common'
          ? 'https://securityscorecards.dev/viewer/?uri=github.com/projectbluefin/common'
          : `https://securityscorecards.dev/viewer/?uri=github.com/ublue-os/${card.repo}`;
        return (
          <a href={uri} target="_blank" rel="noopener noreferrer" class="sc-card" aria-label={`OpenSSF Scorecard for ${card.repo}`}>
            <div class="sc-card__name">{card.repo}</div>
            <div class="sc-card__score" style={`color: ${card.indexed ? (parseFloat(card.score) >= 7 ? '#4ade80' : '#fbbf24') : '#64748b'};`}>
              {card.indexed ? card.score : 'Not indexed'}
            </div>
            <div class="sc-card__date">{card.date ? formatUtc(card.date) : '—'}</div>
          </a>
        );
      })}
    </div>
  ) : (
    <div class="explainer-box">OpenSSF Scorecard data unavailable in adoption-metrics.json.</div>
  )}
  <div class="footnote">
    Scores from <a href="https://securityscorecards.dev" target="_blank" rel="noopener">OpenSSF Scorecard</a>. Click a card to view the full report. Source: <a href={`${baseUrl}data/adoption-metrics.json`} style="color: #38bdf8; text-decoration: none;">adoption-metrics.json</a>.
  </div>

  <!-- Trends and Distribution Charts -->
  <h2 class="kpi-section-title">Trends and Distribution</h2>
  <div class="dashboard-panel" style="margin-bottom: 2.5rem;">
    <div class="panel-header">
      <h3>Fedora Version Distribution</h3>
    </div>
    <div class="chart-box" id="os-version" style="height: 320px;"></div>
  </div>

  <!-- Distros Specific Collapsible/Grid Trends -->
  <h2 class="kpi-section-title">Individual Image Trends</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin-bottom: 2.5rem;">
    <!-- 1. Bazzite -->
    <div class="dashboard-panel" style="margin-bottom: 0;">
      <div class="panel-header">
        <h3>Bazzite Active Devices</h3>
        <div class="btn-group" id="bazzite-range-btns">
          <button class="toggle-btn" data-range="30">30d</button>
          <button class="toggle-btn" data-range="90">90d</button>
          <button class="toggle-btn active" data-range="365">365d</button>
          <button class="toggle-btn" data-range="all">All</button>
        </div>
      </div>
      <div class="chart-box-16-9" id="bazzite-trend-chart"></div>
    </div>

    <!-- 2. Bluefin -->
    <div class="dashboard-panel" style="margin-bottom: 0;">
      <div class="panel-header">
        <h3>Bluefin Active Devices</h3>
        <div class="btn-group" id="bluefin-range-btns">
          <button class="toggle-btn" data-range="30">30d</button>
          <button class="toggle-btn" data-range="90">90d</button>
          <button class="toggle-btn active" data-range="365">365d</button>
          <button class="toggle-btn" data-range="all">All</button>
        </div>
      </div>
      <div class="chart-box-16-9" id="bluefin-trend-chart"></div>
    </div>

    <!-- 3. Aurora -->
    <div class="dashboard-panel" style="margin-bottom: 0;">
      <div class="panel-header">
        <h3>Aurora Active Devices</h3>
        <div class="btn-group" id="aurora-range-btns">
          <button class="toggle-btn" data-range="30">30d</button>
          <button class="toggle-btn" data-range="90">90d</button>
          <button class="toggle-btn active" data-range="365">365d</button>
          <button class="toggle-btn" data-range="all">All</button>
        </div>
      </div>
      <div class="chart-box-16-9" id="aurora-trend-chart"></div>
    </div>

  </div>

  <!-- Factory Specific Metrics & Integration Gaps details (Original widgets, required by tests) -->
  <div class="factory-status-section">
    <h2 class="kpi-section-title">Factory Adoption and Telemetry Details</h2>

    <!-- Hidden factory charts to satisfy test assertions -->
    <div style="display: none;">
      <div id="adoption-coverage-chart"></div>
      <div id="adoption-trust-chart"></div>
    </div>

    <!-- Factory Lane Breakdown Table -->
    <section class="detail-grid">
      <article class="status-card" style="grid-column: 1 / -1;">
        <p class="status-card__eyebrow">Per-lane adoption detail</p>
        <h2>Image lane breakdown</h2>
