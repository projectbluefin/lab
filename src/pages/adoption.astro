          },
          yAxis: { type: 'value', axisLabel: { color: '#cbd5f5', formatter: function(v) { return v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v; } }, splitLine: { lineStyle: { color: 'rgba(255,255,255,0.04)' } } },
          series: [
            { name: '90d Installs', type: 'bar', data: tapComp.map(function(t) { return t.installs; }), itemStyle: { color: '#38bdf8', borderRadius: [4,4,0,0] } },
            { name: 'Downloads',   type: 'bar', data: tapComp.map(function(t) { return t.downloads; }), itemStyle: { color: '#818cf8', borderRadius: [4,4,0,0] } },
            { name: 'Packages',    type: 'bar', data: tapComp.map(function(t) { return t.packages; }), itemStyle: { color: '#fb923c', borderRadius: [4,4,0,0] } },
          ],
        });
      } else {
        renderUnavailable('tap-installs-chart', 'Tap analytics data pending.');
      }
    }

    function bootHomebrewPkgTypeChart() {
      if (!pageData || !pageData.homebrew) return;
      var pts = Array.isArray(pageData.homebrew.packageTypeSplit) ? pageData.homebrew.packageTypeSplit : [];
      var ptEl = document.getElementById('pkg-type-chart');
      if (!ptEl) return;
      if (pts.length > 0) {
        var ptChart = window.echarts.init(ptEl);
        ptChart.setOption({
          tooltip: { backgroundColor: 'rgba(15, 23, 42, 0.9)', borderColor: 'rgba(255, 255, 255, 0.1)', textStyle: { color: '#cbd5e1' }, trigger: 'axis', axisPointer: { type: 'shadow' } },
          legend: { data: ['Formula', 'Cask'], textStyle: { color: '#cbd5f5' }, top: 0 },
          grid: { left: 80, right: 20, top: 36, bottom: 50 },
          xAxis: { type: 'category', data: pts.map(function(t) { return t.name; }), axisLabel: { color: '#cbd5f5', rotate: 10 }, axisLine: { lineStyle: { color: 'rgba(255,255,255,0.1)' } } },
          yAxis: { type: 'value', axisLabel: { color: '#cbd5f5' }, splitLine: { lineStyle: { color: 'rgba(255,255,255,0.04)' } } },
          series: [
            { name: 'Formula', type: 'bar', stack: 'pkg', data: pts.map(function(t) { return t.formula; }), itemStyle: { color: '#22d3ee' } },
            { name: 'Cask',    type: 'bar', stack: 'pkg', data: pts.map(function(t) { return t.cask; }),    itemStyle: { color: '#f472b6', borderRadius: [4,4,0,0] } },
          ],
        });
      } else {
        renderUnavailable('pkg-type-chart', 'Package type breakdown pending.');
      }
    }

    function bootHomebrewCoverageDonutChart() {
      if (!pageData || !pageData.homebrew) return;
      var donut = Array.isArray(pageData.homebrew.coverageDonut) ? pageData.homebrew.coverageDonut : [];
      var dnEl = document.getElementById('coverage-donut-chart');
      if (!dnEl) return;
      if (donut.length > 0) {
        var dnChart = window.echarts.init(dnEl);
        dnChart.setOption({
          tooltip: { backgroundColor: 'rgba(15, 23, 42, 0.9)', borderColor: 'rgba(255, 255, 255, 0.1)', textStyle: { color: '#cbd5e1' }, trigger: 'item', formatter: '{b}: {c} lanes ({d}%)' },
          legend: { orient: 'horizontal', bottom: 4, textStyle: { color: '#cbd5f5' } },
          series: [{
            name: 'Lane coverage',
            type: 'pie',
            radius: ['45%', '70%'],
            center: ['50%', '45%'],
            data: donut,
            label: { color: '#e2e8f0', fontSize: 11 },
            emphasis: { itemStyle: { shadowBlur: 10, shadowOffsetX: 0, shadowColor: 'rgba(0,0,0,.5)' } },
          }],
        });
      } else {
        renderUnavailable('coverage-donut-chart', 'Coverage data pending.');
      }
    }

    function bootHomebrewPackagesChart() {
      if (!pageData || !pageData.homebrew) return;
      var topPkgs = Array.isArray(pageData.homebrew.topPackages) ? pageData.homebrew.topPackages : [];
      var pkgsEl  = document.getElementById('homebrew-packages-chart');
      if (!pkgsEl) return;
      if (topPkgs.length > 0) {
        var revPkgs = topPkgs.slice().reverse();
        var pkgChart = window.echarts.init(pkgsEl);
        pkgChart.setOption({
          tooltip: {
            backgroundColor: 'rgba(15, 23, 42, 0.9)', borderColor: 'rgba(255, 255, 255, 0.1)', textStyle: { color: '#cbd5e1' },
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            formatter: function(params) {
              var idx  = params[0].dataIndex;
              var pkg  = revPkgs[idx];
              return [
                '<strong>' + pkg.name + '</strong>',
                'Tap: '              + (pkg.tap      || 'Unknown'),
                'Installs (90d): '   + (pkg.installs !== null ? pkg.installs.toLocaleString() : 'Unavailable'),
                'Downloads: '        + (pkg.downloads !== null ? pkg.downloads.toLocaleString() : 'Unavailable'),
              ].join('<br>');
            },
          },
          grid: { left: 110, right: 25, top: 20, bottom: 35 },
          xAxis: { type: 'value', axisLabel: { color: '#cbd5f5', formatter: function(v) { return v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v; } }, splitLine: { lineStyle: { color: 'rgba(255,255,255,0.04)' } } },
          yAxis: { type: 'category', data: revPkgs.map(function(p) { return p.name; }), axisLabel: { color: '#cbd5f5' } },
          series: [{
            name: 'Installs',
            type: 'bar',
            data: revPkgs.map(function(p) { return p.installs; }),
            itemStyle: {
              borderRadius: [0, 4, 4, 0],
              color: new window.echarts.graphic.LinearGradient(0, 0, 1, 0, [
                { offset: 0, color: '#0ea5e9' },
                { offset: 1, color: '#38bdf8' },
              ]),
            },
          }],
        });
      } else {
        renderUnavailable('homebrew-packages-chart', 'No package telemetry available.');
      }
    }

    function bootHomebrewLanesChart() {
      if (!pageData || !pageData.homebrew) return;
      var laneIns = Array.isArray(pageData.homebrew.laneInstalls) ? pageData.homebrew.laneInstalls : [];
      var laneEl  = document.getElementById('homebrew-lanes-chart');
      if (!laneEl) return;
      if (laneIns.length > 0) {
        var laneChart = window.echarts.init(laneEl);
        laneChart.setOption({
          tooltip: {
            backgroundColor: 'rgba(15, 23, 42, 0.9)', borderColor: 'rgba(255, 255, 255, 0.1)', textStyle: { color: '#cbd5e1' },
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            formatter: function(params) {
              var li = laneIns[params[0].dataIndex];
              return [
                '<strong>' + li.label + '</strong>',
                'Installs (90d): '  + li.installs.toLocaleString(),
                'Downloads: '       + li.downloads.toLocaleString(),
              ].join('<br>');
            },
          },
          grid: { left: 120, right: 20, top: 20, bottom: 30 },
          xAxis: { type: 'value', axisLabel: { color: '#cbd5f5', formatter: function(v) { return v >= 1e6 ? (v/1e6).toFixed(1)+'M' : v >= 1e3 ? (v/1e3).toFixed(0)+'K' : v; } }, splitLine: { lineStyle: { color: 'rgba(255,255,255,0.04)' } } },
          yAxis: { type: 'category', data: laneIns.map(function(l) { return l.label; }), axisLabel: { color: '#cbd5f5' } },
          series: [
            {
              name: 'Installs',
              type: 'bar',
              data: laneIns.map(function(l) { return l.installs; }),
              itemStyle: { borderRadius: [0,4,4,0], color: new window.echarts.graphic.LinearGradient(0,0,1,0,[{offset:0,color:'#059669'},{offset:1,color:'#34d399'}]) },
              label: { show: true, position: 'right', color: '#94a3b8', fontSize: 11, formatter: function(p) { return (p.value/1e6).toFixed(1)+'M'; } },
            },
          ],
        });
      } else {
        renderUnavailable('homebrew-lanes-chart', 'Per-lane install data pending.');
      }
    }

    function setupLazyLoading() {
      function lazyInit(elementId, bootFn) {
        const el = document.getElementById(elementId);
        if (!el) return;
        if (typeof IntersectionObserver !== 'undefined') {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                bootFn();
                observer.unobserve(el);
              }
            });
          }, { rootMargin: '100px' });
          observer.observe(el);
        } else {
          bootFn();
        }
      }

      lazyInit('cumulative-installations-chart', bootCumulativeInstallationsChart);
      lazyInit('adoption-sankey-chart', bootAdoptionSankeyChart);
      lazyInit('countme-trend-chart', bootCountmeTrendChart);
      lazyInit('ecosystem-pie-chart', bootEcosystemPieChart);
      lazyInit('quay-trend', bootQuayTrendChart);
      lazyInit('lane-breakdown-chart', bootLaneBreakdownChart);
      lazyInit('os-version', bootOsVersionChart);
      
      // Individual distro charts
      lazyInit('bazzite-trend-chart', function() { bootIndividualDistroChart('bazzite'); });
      lazyInit('bluefin-trend-chart', function() { bootIndividualDistroChart('bluefin'); });
      lazyInit('aurora-trend-chart', function() { bootIndividualDistroChart('aurora'); });

      // Legacy containers for test compatibility
      lazyInit('adoption-coverage-chart', bootLegacyCoverageChart);
      lazyInit('adoption-trust-chart', bootLegacyTrustChart);

      // Homebrew charts
      lazyInit('tap-installs-chart', bootHomebrewTapInstallsChart);
      lazyInit('pkg-type-chart', bootHomebrewPkgTypeChart);
      lazyInit('coverage-donut-chart', bootHomebrewCoverageDonutChart);
      lazyInit('homebrew-packages-chart', bootHomebrewPackagesChart);
      lazyInit('homebrew-lanes-chart', bootHomebrewLanesChart);
    }

    function waitForCharts(attempt) {
      if (attempt === undefined) attempt = 0;
      if (window.echarts) {
        bootSparklines();
        setupLazyLoading();
        return;
      }
      if (attempt > 40) {
        renderUnavailable('cumulative-installations-chart', 'ECharts failed to load. Table below remains the source of truth.');
        renderUnavailable('adoption-sankey-chart', 'Sankey chart unavailable because the chart runtime did not load.');
        return;
      }
      window.setTimeout(function() { waitForCharts(attempt + 1); }, 125);
    }

    window.addEventListener('resize', function() {
      document.querySelectorAll('.chart-surface, .chart-box, .chart-box-large, .chart-box-16-9, #lane-breakdown-chart, .kpi-card__sparkline').forEach(function(element) {
        var instance = window.echarts.getInstanceByDom(element);
        if (instance) instance.resize();
      });
    });

    waitForCharts();
  </script>
</SiteLayout>
