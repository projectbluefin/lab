---
import SiteLayout from '../layouts/SiteLayout.astro';
import { loadHomebrewPageModel } from '../lib/homebrew-page';
import { serializeJsonScript } from '../lib/json-script';

const baseUrl = import.meta.env.BASE_URL;
const pageModel = loadHomebrewPageModel(`${process.cwd()}/docs/data/homebrew-ecosystem.json`);

const {
  dataset,
  summaryMetrics,
  taps,
  rows,
  availableRows,
  unavailableRows,
  packageLeaderboard,
  tapDensityRows,
  tapDensitySummary,
  chartData,
} = pageModel;

const serializedPageData = serializeJsonScript(chartData);

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';
---

<SiteLayout
  title="Homebrew"
  description="Homebrew tap and package ecosystem coverage across all tracked Project Bluefin factory image lanes."
  current="homebrew"
>
  <section class="summary-grid" aria-label="Homebrew summary metrics">
    {summaryMetrics.map((metric) => (
      <article class="metric-card">
        <p class="metric-card__label">{metric.label}</p>
        <p class="metric-card__value">{metric.value}</p>
        <p class="metric-card__meta">
          <span>{metric.unit}</span>
          <a href={metric.source_url}>Evidence</a>
        </p>
      </article>
    ))}
  </section>

  <section class="chart-grid chart-grid--hero" aria-label="Homebrew ecosystem telemetry">
    <article class="status-card chart-card">
      <p class="status-card__eyebrow">Coverage across all tracked image lanes</p>
      <h2>Lane coverage status</h2>
      <p class="table-note">
        Visualizes which lanes have active Homebrew tap and formula analytics data available or pending.
      </p>
      <div id="homebrew-lanes-chart" class="chart-surface" style="height: 320px;" role="img" aria-label="Homebrew lane coverage status chart"></div>
    </article>

    <article class="status-card chart-card">
      <p class="status-card__eyebrow">Telemetry ranking</p>
      <h2>Top packages by 90d installs</h2>
      <p class="table-note">
        Most popular packages across the tracked taps (e.g. bluefin/brewfile) ranked by installs.
      </p>
      <div id="homebrew-packages-chart" class="chart-surface" style="height: 320px;" role="img" aria-label="Top packages leaderboard chart"></div>
    </article>
  </section>

  <section class="detail-grid">
    <article class="status-card">
      <p class="status-card__eyebrow">Package-level analytics</p>
      <h2>Package leaderboard</h2>
      <p>
        Dense package-level analytics are grouped from Homebrew package entries and sorted by installs.
        Lanes with missing analytics remain visible in the density table below.
      </p>
      {packageLeaderboard.length === 0 ? (
        <p class="table-note">
          Package leaderboard unavailable. No package-level Homebrew analytics are published in the current dataset.
        </p>
      ) : (
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">Package</th>
                <th scope="col">Tap</th>
                <th scope="col">Installs (90d)</th>
                <th scope="col">Downloads</th>
                <th scope="col">Status</th>
                <th scope="col">Evidence</th>
              </tr>
            </thead>
            <tbody>
              {packageLeaderboard.map((pkg) => (
                <tr>
                  <th scope="row">{pkg.package_name}</th>
                  <td>
                    {pkg.tap_url ? (
                      <a href={pkg.tap_url}>{pkg.tap_name ?? pkg.tap_url}</a>
                    ) : pkg.tap_name ? (
                      pkg.tap_name
                    ) : (
                      <span class="table-note">Unavailable</span>
                    )}
                  </td>
                  <td>{pkg.install_count !== null ? pkg.install_count.toLocaleString() : <span class="table-note">Unavailable</span>}</td>
                  <td>{pkg.download_count !== null ? pkg.download_count.toLocaleString() : <span class="table-note">Unavailable</span>}</td>
                  <td>
                    <span class:list={['pill', pkg.state === 'available' ? 'pill--pass' : 'pill--missing']}>
                      {pkg.state}
                    </span>
                    {pkg.state !== 'available' && pkg.state_reason && <p class="table-note">{pkg.state_reason}</p>}
                  </td>
                  <td><a href={pkg.source_url}>Source</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </article>

    <article class="status-card">
      <p class="status-card__eyebrow">Tap density across tracked lanes</p>
      <h2>Tap density across tracked lanes</h2>
      <dl class="status-card__meta">
        <div>
          <dt>Lanes with package density</dt>
          <dd>{tapDensitySummary.lanesWithPackageDensity}</dd>
        </div>
        <div>
          <dt>Lanes awaiting package density</dt>
          <dd>{tapDensitySummary.lanesAwaitingPackageDensity}</dd>
        </div>
        <div>
          <dt>Packages in tap scope</dt>
          <dd>{tapDensitySummary.totalPackagesInScope}</dd>
        </div>
        <div>
          <dt>Distinct taps with packages</dt>
          <dd>{tapDensitySummary.distinctTapsWithPackages}</dd>
        </div>
        <div>
          <dt>Average packages per covered lane</dt>
          <dd>{tapDensitySummary.averagePackagesPerLane}</dd>
        </div>
      </dl>
      <div class="table-scroll">
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">Lane</th>
              <th scope="col">Tap</th>
              <th scope="col">Package count</th>
              <th scope="col">Lane installs</th>
              <th scope="col">Lane downloads</th>
              <th scope="col">Status</th>
              <th scope="col">Evidence</th>
            </tr>
          </thead>
          <tbody>
            {tapDensityRows.map((lane) => (
              <tr>
                <th scope="row">{lane.lane_label}</th>
                <td>
                  {lane.tap_url ? (
                    <a href={lane.tap_url}>{lane.tap_name ?? lane.tap_url}</a>
                  ) : lane.tap_name ? (
                    lane.tap_name
                  ) : (
                    <span class="table-note">Unavailable</span>
                  )}
                </td>
                <td>{lane.package_count !== null ? lane.package_count.toLocaleString() : <span class="table-note">Unavailable</span>}</td>
                <td>{lane.install_count !== null ? lane.install_count.toLocaleString() : <span class="table-note">Unavailable</span>}</td>
                <td>{lane.download_count !== null ? lane.download_count.toLocaleString() : <span class="table-note">Unavailable</span>}</td>
                <td>
                  <span class:list={['pill', lane.state === 'available' ? 'pill--pass' : 'pill--missing']}>
                    {lane.state}
                  </span>
                  {lane.state !== 'available' && lane.state_reason && <p class="table-note">{lane.state_reason}</p>}
                </td>
                <td><a href={lane.source_url}>Source</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>
  </section>

  <section class="detail-grid">
    <article class="status-card">
      <p class="status-card__eyebrow">Per-lane Homebrew details</p>
      <h2>All tracked image lanes</h2>
      {availableRows.length > 0 && (
        <p class="callout-note">{availableRows[0].derivation}</p>
      )}
      <div class="table-scroll">
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">Variant</th>
              <th scope="col">Branch</th>
              <th scope="col">Tap</th>
              <th scope="col">Installs</th>
              <th scope="col">Downloads</th>
              <th scope="col">Status</th>
              <th scope="col">Evidence</th>
            </tr>
          </thead>
          <tbody>
            {rows.map((row) => (
              <tr>
                <th scope="row">{row.variant}</th>
                <td>{row.branch}</td>
                <td>
                  {row.tap_url ? (
                    <a href={row.tap_url}>{row.tap_name ?? row.tap_url}</a>
                  ) : (
                    <span class="table-note">None tracked</span>
                  )}
                </td>
                <td>
                  {row.install_count !== null ? (
                    row.install_count.toLocaleString()
                  ) : (
                    <span class="table-note">Unavailable</span>
                  )}
                </td>
                <td>
                  {row.download_count !== null ? (
                    row.download_count.toLocaleString()
                  ) : (
                    <span class="table-note">Unavailable</span>
                  )}
                </td>
                <td>
                  <span class:list={['pill', row.state === 'available' ? 'pill--pass' : 'pill--missing']}>
                    {row.state}
                  </span>
                  {row.state !== 'available' && (
                    <p class="table-note">{row.state_reason}</p>
                  )}
                </td>
                <td>
                  <a href={row.source_url}>Source</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </article>

    {taps.length > 0 && (
      <article class="status-card">
        <p class="status-card__eyebrow">Tracked taps</p>
        <h2>Homebrew tap registry</h2>
        <div class="table-scroll">
          <table class="data-table">
            <thead>
              <tr>
                <th scope="col">Tap name</th>
                <th scope="col">URL</th>
                <th scope="col">Status</th>
                <th scope="col">Evidence</th>
              </tr>
            </thead>
            <tbody>
              {taps.map((tap) => (
                <tr>
                  <th scope="row">{tap.name}</th>
                  <td><a href={tap.url}>{tap.url}</a></td>
                  <td>
                    <span class:list={['pill', tap.state === 'available' ? 'pill--pass' : 'pill--missing']}>
                      {tap.state}
                    </span>
                  </td>
                  <td><a href={tap.source_url}>Source</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </article>
    )}
  </section>

  <section class="detail-grid">
    <article class="status-card">
      <p class="status-card__eyebrow">Dataset provenance</p>
      <h2>Collector-derived contract</h2>
      <dl class="status-card__meta">
        <div>
          <dt>Schema version</dt>
          <dd>{dataset.schema_version}</dd>
        </div>
        <div>
          <dt>Generated at</dt>
          <dd>{formatUtc(dataset._meta.generated_at)}</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>{dataset._meta.status}</dd>
        </div>
      </dl>
      <p class="table-note">{dataset._meta.description}</p>

      <div class="integrity-disclosure" style="margin-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.08); padding-top: 1rem;">
        <h4 style="font-size: 0.875rem; color: #cbd5e1; margin-bottom: 0.5rem;">Data Integrity Posture Disclosures</h4>
        <ul class="status-list table-note" style="padding-left: 1rem; list-style-type: disc;">
          <li>Homebrew integration status: <span class="pill pill--pass">Homebrew data is partially available</span></li>
          <li>Formula-level analytics from formulae.brew.sh are merged with repo-tracked Tap scope Brewfile packages.</li>
          <li>{unavailableRows.length} of {rows.length} lanes lack Homebrew analytics data from formulae.brew.sh or upstream tap repos.</li>
          <li>{taps.length} Homebrew tap(s) explicitly tracked in this dataset.</li>
          <li>No Homebrew install or download counts are fabricated. Data gaps stay labeled rather than disappearing.</li>
          <li>This page reads repo-owned migrated Homebrew artifacts committed under <code>docs/data/</code>. Mapped tap lanes reuse transplanted Brewfile package totals, higher-density lane markers stay visible, and unmatched lanes remain explicitly unavailable.</li>
          <li>Global formula analytics transplanted for a 115-package tap (e.g. bluefin/brewfile) and 20-package tap (e.g. bazzite/brewfile) are reused across branches.</li>
        </ul>
      </div>

      <a href={`${baseUrl}data/homebrew-ecosystem.json`} style="margin-top: 1rem; display: inline-block;">Open raw dataset</a>
    </article>
  </section>

  <script id="homebrew-page-data" type="application/json" set:html={serializedPageData}></script>
  <script
    is:inline
    src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"
    defer
    data-cfasync="false"
  ></script>
  <script is:inline data-cfasync="false">
    const dataNode = document.getElementById('homebrew-page-data');
    const pageData = dataNode ? JSON.parse(dataNode.textContent || '{}') : null;

    function renderUnavailable(containerId, message) {
      const container = document.getElementById(containerId);
      if (!container) return;
      container.innerHTML = `<div class="chart-empty">${message}</div>`;
    }

    function waitForCharts(attempt) {
      if (attempt === undefined) attempt = 0;
      if (window.echarts) {
        bootCharts(window.echarts);
        return;
      }
      if (attempt > 40) {
        renderUnavailable('homebrew-lanes-chart', 'ECharts failed to load. Table below remains the source of truth.');
        renderUnavailable('homebrew-packages-chart', 'Top packages chart unavailable because the chart runtime did not load.');
        return;
      }
      window.setTimeout(function () { waitForCharts(attempt + 1); }, 125);
    }

    function bootCharts(echarts) {
      if (!pageData) return;

      // 1. Lane Coverage Status Chart
      var lanes = Array.isArray(pageData.laneStatus) ? pageData.laneStatus : [];
      if (lanes.length === 0) {
        renderUnavailable('homebrew-lanes-chart', 'No lane data published in homebrew-ecosystem.json.');
      } else {
        var laneContainer = document.getElementById('homebrew-lanes-chart');
        if (laneContainer) {
          var hasAnyData = lanes.some(function (l) { return l.stateScore > 0; });
          if (!hasAnyData) {
            renderUnavailable(
              'homebrew-lanes-chart',
              'No Homebrew analytics data is available for any tracked lane yet. ' +
              'Once a repo-owned artifact from formulae.brew.sh or upstream tap repos is committed to docs/data/, ' +
              'this chart will populate automatically.'
            );
          } else {
            var chart = echarts.init(laneContainer);
            chart.setOption({
              aria: { enabled: true },
              tooltip: {
                trigger: 'axis',
                axisPointer: { type: 'shadow' },
                formatter: function (params) {
                  var lane = lanes[params[0].dataIndex];
                  return [
                    '<strong>' + lane.label + '</strong>',
                    lane.stateLabel,
                    lane.installCount !== null ? 'Installs: ' + lane.installCount.toLocaleString() : 'Installs: unavailable',
                    lane.downloadCount !== null ? 'Downloads: ' + lane.downloadCount.toLocaleString() : 'Downloads: unavailable',
                  ].join('<br>');
                },
              },
              grid: { left: 65, right: 20, top: 20, bottom: 65 },
              xAxis: {
                type: 'category',
                data: lanes.map(function (l) { return l.label; }),
                axisLabel: { color: '#cbd5f5', rotate: 30 },
              },
              yAxis: {
                type: 'value',
                max: 2,
                interval: 1,
                axisLabel: {
                  color: '#cbd5f5',
                  formatter: function (value) {
                    if (value === 0) return 'Awaiting';
                    if (value === 1) return 'Tracked';
                    if (value === 2) return 'Available';
                    return '';
                  },
                },
              },
              series: [
                {
                  name: 'Data coverage',
                  type: 'bar',
                  data: lanes.map(function (l) { return l.stateScore; }),
                  itemStyle: {
                    color: function (params) {
                      var score = params.data;
                      if (score === 2) return '#22c55e';
                      if (score === 1) return '#f59e0b';
                      return '#334155';
                    },
                  },
                },
              ],
            });
          }
        }
      }

      // 2. Top Packages Leaderboard Chart
      var pkgsContainer = document.getElementById('homebrew-packages-chart');
      var topPkgs = Array.isArray(pageData.topPackages) ? pageData.topPackages : [];
      if (pkgsContainer && topPkgs.length > 0) {
        var pkgsChart = echarts.init(pkgsContainer);
        var reversedPkgs = [...topPkgs].reverse();
        pkgsChart.setOption({
          tooltip: {
            trigger: 'axis',
            axisPointer: { type: 'shadow' },
            backgroundColor: 'rgba(15, 23, 42, 0.9)',
            borderColor: 'rgba(255, 255, 255, 0.1)',
            textStyle: { color: '#cbd5e1' },
            formatter: function (params) {
              var idx = params[0].dataIndex;
              var pkg = reversedPkgs[idx];
              return [
                '<strong>' + pkg.name + '</strong>',
                'Tap: ' + (pkg.tap || 'Unknown'),
                'Installs (90d): ' + (pkg.installs !== null ? pkg.installs.toLocaleString() : 'Unavailable'),
                'Downloads: ' + (pkg.downloads !== null ? pkg.downloads.toLocaleString() : 'Unavailable')
              ].join('<br>');
            }
          },
          grid: { left: 95, right: 25, top: 20, bottom: 35 },
          xAxis: {
            type: 'value',
            axisLabel: { color: '#cbd5f5' },
            splitLine: { lineStyle: { color: 'rgba(255,255,255,0.04)' } }
          },
          yAxis: {
            type: 'category',
            data: reversedPkgs.map(function (pkg) { return pkg.name; }),
            axisLabel: { color: '#cbd5f5' }
          },
          series: [{
            name: 'Installs',
            type: 'bar',
            data: reversedPkgs.map(function (pkg) { return pkg.installs; }),
            itemStyle: {
              color: '#38bdf8',
              borderRadius: [0, 4, 4, 0]
            }
          }]
        });
      } else {
        renderUnavailable('homebrew-packages-chart', 'No package telemetry available in homebrew-ecosystem.json.');
      }

      window.addEventListener('resize', function () {
        document.querySelectorAll('.chart-surface').forEach(function (element) {
          var instance = echarts.getInstanceByDom(element);
          if (instance) instance.resize();
        });
      });
    }

    waitForCharts();
  </script>
</SiteLayout>
