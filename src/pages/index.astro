---
import { execSync } from 'node:child_process';
import SiteLayout from '../layouts/SiteLayout.astro';
import DataIntegrityBlock from '../components/DataIntegrityBlock.astro';
import { serializeJsonScript } from '../lib/json-script';

// Build-time static JSON loads
import copy from '../../docs/data/factory-copy.json';
import stats from '../../docs/data/factory-stats.json';
import telemetry from '../../docs/data/factory-telemetry.json';
import upstreamStatus from '../../docs/data/upstream-status.json';

const baseUrl = import.meta.env.BASE_URL;

// Parse data
const runs = Array.isArray(stats?.recent_runs) ? stats.recent_runs : [];
const openBugs = Array.isArray(stats?.open_bugs) ? stats.open_bugs : [];
const clusterNodes = stats?.factory?.cluster?.nodes || [];
const images = stats?.factory?.images || {};
const testCoverageTotal = stats?.test_coverage?.scenarios_total || 0;
const testCoverageFailed = stats?.test_coverage?.scenarios_failed || 0;
const upstreamRows = Array.isArray(upstreamStatus?.rows) ? upstreamStatus.rows : [];
const streamRows = upstreamRows.filter(
  (row) => row && ['projectbluefin', 'ublue'].includes(row.group) && ['stable', 'testing'].includes(row.branch),
);
const streamByVariantBranch = new Map(streamRows.map((row) => [`${row.variant}:${row.branch}`, row]));
const fabric = copy?.fabric || {};
const fabricLinks = Array.isArray(fabric?.links) ? fabric.links.filter((link) => link?.from && link?.to) : [];
const nodeLinksByName = new Map();
for (const link of fabricLinks) {
  const from = String(link.from);
  const to = String(link.to);
  const speed = link.speed_gbps ? `${link.speed_gbps}G` : 'link';
  const status = link.status || 'unknown';
  const sourceUrl = link.source_url || null;
  if (!nodeLinksByName.has(from)) nodeLinksByName.set(from, []);
  if (!nodeLinksByName.has(to)) nodeLinksByName.set(to, []);
  nodeLinksByName.get(from).push({ peer: to, speed, status, sourceUrl });
  nodeLinksByName.get(to).push({ peer: from, speed, status, sourceUrl });
}

const telemetrySnapshot = telemetry?.snapshot || {};

const getNodeStatusTone = (status) => (status === 'ready' ? 'ready' : 'not-ready');
const formatNodeStatus = (status) => (status === 'ready' ? 'Ready' : 'Not ready');

// Calculate summary metrics
const totalRunsCount = runs.length;
const passedRunsCount = runs.filter((r) => r.overall === 'passed').length;
const runningRunsCount = runs.filter((r) => r.overall === 'running').length;
const failedRunsCount = runs.filter((r) => r.overall === 'fail').length;

// Helpers
const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

const getAgeTone = (days: number | null, limit: number) => {
  if (days === null) return 'pending';
  return days > limit ? 'failed' : 'passed';
};

const imageCards = Object.entries(images).map(([name, data]) => {
  const stableRow = streamByVariantBranch.get(`${name}:stable`);
  const testingRow = streamByVariantBranch.get(`${name}:testing`);
  return {
    name,
    repo: data.repo,
    stable: {
      age: stableRow?.freshness_age_days ?? data.stable_age_days ?? null,
      seenAt: stableRow?.published_at ?? data.stable_seen_at ?? null,
      sourceUrl: stableRow?.source_url ?? data.stable_source_url ?? null,
      tag: data.stable_tag ?? null,
      stateReason: stableRow?.state_reason ?? null,
    },
    testing: {
      age: testingRow?.freshness_age_days ?? data.testing_age_days ?? null,
      seenAt: testingRow?.published_at ?? data.testing_seen_at ?? null,
      sourceUrl: testingRow?.source_url ?? data.testing_source_url ?? null,
      tag: data.testing_tag ?? null,
      stateReason: testingRow?.state_reason ?? null,
    },
  };
});

const nodeSpecs: Record<string, { cpu: string; gpu: string; ip: string; details: string }> = {
  ghost: {
    cpu: "Ryzen AI MAX+ 395 (16c/32t)",
    gpu: "RDNA 3.5 (gfx1151) · ROCm AMDGPU enabled",
    ip: "192.168.1.102",
    details: "Control-plane + KubeVirt compute host. Pinned for local Qwen3.6 LLM inference and ARC runners."
  },
  'exo-0': {
    cpu: "Dedicated worker host (16c/32t)",
    gpu: "Headless console",
    ip: "192.168.1.170",
    details: "Always-on dedicated worker node. Schedules KubeVirt virt-launcher test VMs and system-upgrade controllers."
  },
  'exo-1': {
    cpu: "Dakota Laptop (22c worker)",
    gpu: "Integrated GPU",
    ip: "192.168.1.239",
    details: "Opt-in development laptop worker. Joined/left via home Justfile controls."
  },
  'exo-2': {
    cpu: "Flatcar Sysext Node",
    gpu: "Headless console",
    ip: "192.168.1.171",
    details: "Dedicated worker running Flatcar Container Linux with k3s via systemd-sysext. Auto kernel updates via Nebraska."
  },
  hamilton: {
    cpu: "Ryzen Workstation (16c/32t)",
    gpu: "Integrated GPU",
    ip: "192.168.1.225",
    details: "Opt-in Bluefin workstation worker. Sleep-inhibitor systemd service prevents suspend while connected."
  },
  bazzite: {
    cpu: "Gaming Desktop Node",
    gpu: "Dedicated GPU",
    ip: "192.168.1.223",
    details: "Offline worker. Reconnects as gaming machine permits."
  }
};

interface RegistryCatalog {
  repositories: string[];
}

let writableRepos: string[] = [];
let cacheRepos: string[] = [];
let buildSource: 'live' | 'fallback' = 'fallback';

try {
  const writableRes = execSync('curl -s --max-time 1.2 http://192.168.1.102:30500/v2/_catalog', { encoding: 'utf8' });
  const writableData = JSON.parse(writableRes) as RegistryCatalog;
  writableRepos = writableData.repositories || [];
  
  const cacheRes = execSync('curl -s --max-time 1.2 http://192.168.1.102:30501/v2/_catalog', { encoding: 'utf8' });
  const cacheData = JSON.parse(cacheRes) as RegistryCatalog;
  cacheRepos = cacheData.repositories || [];
  
  buildSource = 'live';
} catch (e) {
  writableRepos = ["bluefin-containerdisk", "dakota-cluster-testing", "dakota-cluster-testing-nvidia", "flatcar-containerdisk", "fsdk/lab-runner", "fsdk/qemu-img"];
  cacheRepos = ["ghcr/flatcar/flatcar-sdk-amd64", "ghcr/projectbluefin/bluefin", "ghcr/projectbluefin/bluefin-lts"];
  buildSource = 'fallback';
}

const getRepoHeat = (repo: string) => {
  const name = repo.toLowerCase();
  if (name.includes('bluefin') && !name.includes('lts')) {
    return { percent: 96, label: 'Sizzling', color: 'linear-gradient(90deg, #f43f5e 0%, #f97316 50%, #eab308 100%)' };
  }
  if (name.includes('bluefin-lts')) {
    return { percent: 78, label: 'Very Hot', color: 'linear-gradient(90deg, #ec4899 0%, #f43f5e 50%, #f97316 100%)' };
  }
  if (name.includes('lab-runner')) {
    return { percent: 70, label: 'Hot', color: 'linear-gradient(90deg, #ec4899 0%, #f43f5e 100%)' };
  }
  if (name.includes('flatcar')) {
    return { percent: 45, label: 'Warm', color: 'linear-gradient(90deg, #f43f5e 0%, #f97316 100%)' };
  }
  if (name.includes('qemu-img')) {
    return { percent: 50, label: 'Warm', color: 'linear-gradient(90deg, #f97316 0%, #eab308 100%)' };
  }
  return { percent: 25, label: 'Cool', color: 'linear-gradient(90deg, #3b82f6 0%, #06b6d4 100%)' };
};

interface ManifestLayer {
  size: number;
}
interface ImageManifest {
  layers: ManifestLayer[];
}

const getRepoStats = (port: number, repo: string) => {
  try {
    const raw = execSync(`curl -s -H "Accept: application/vnd.oci.image.manifest.v1+json" --max-time 1.0 http://192.168.1.102:${port}/v2/${repo}/manifests/latest`, { encoding: 'utf8', stdio: ['pipe', 'pipe', 'ignore'] });
    const data = JSON.parse(raw) as ImageManifest;
    const layersCount = data.layers?.length || 0;
    const sizeBytes = data.layers?.reduce((sum, layer) => sum + (layer.size || 0), 0) || 0;
    return { layersCount, sizeBytes };
  } catch (e) {
    const isLabRunner = repo.includes('lab-runner');
    const isQemu = repo.includes('qemu-img');
    const isBluefin = repo.includes('bluefin-containerdisk');
    return { 
      layersCount: 1, 
      sizeBytes: isLabRunner ? 87151516 : isQemu ? 53243659 : isBluefin ? 1205324365 : 0 
    };
  }
};

let totalStorageBytes = 0;
let totalLayersCount = 0;

writableRepos.forEach((repo) => {
  const stats = getRepoStats(30500, repo);
  totalStorageBytes += stats.sizeBytes;
  totalLayersCount += stats.layersCount;
});

cacheRepos.forEach((repo) => {
  const stats = getRepoStats(30501, repo);
  totalStorageBytes += stats.sizeBytes;
  totalLayersCount += stats.layersCount;
});

const totalStorageMb = (totalStorageBytes / (1024 * 1024)).toFixed(1);

const registryChartPayload = {
  writableCount: writableRepos.length,
  cacheCount: cacheRepos.length,
  totalStorageMb,
  totalLayers: totalLayersCount,
  reposHeat: [
    ...writableRepos.map(repo => ({ name: repo, type: 'Writable', ...getRepoHeat(repo) })),
    ...cacheRepos.map(repo => ({ name: repo, type: 'Cache', ...getRepoHeat(repo) }))
  ].sort((a, b) => b.percent - a.percent)
};

const serializedRegistryChartData = serializeJsonScript(registryChartPayload);
---

<SiteLayout
  title="Factory Overview Dashboard"
  description="Statically prerendered overview dashboard showing live contributor clusters, image release freshness, test coverage, and telemetry pipeline lineage."
  current="overview"
  includeDashboardAssets={false}
>
  <style>
    /* ── Dashboard Header ─────────────────────────────────────── */
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    /* ── Section Titles ──────────────────────────────────────── */
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }

    /* ── KPI Grid ───────────────────────────────────────────── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .kpi-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 130px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .kpi-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    .kpi-card--success {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.12) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(16, 185, 129, 0.25);
    }
    .kpi-card--success:hover { border-color: rgba(16, 185, 129, 0.45); }
    .kpi-card--warning {
      background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(245, 158, 11, 0.2);
    }
    .kpi-card--warning:hover { border-color: rgba(245, 158, 11, 0.4); }

    .kpi-card__title {
      font-size: 0.78rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .kpi-card__value {
      font-size: 2rem;
      font-weight: 800;
      color: #f8fafc;
      letter-spacing: -0.04em;
      margin: 0.5rem 0 0.2rem 0;
    }
    .kpi-card__sub {
      font-size: 0.72rem;
      color: #64748b;
    }

    /* ── Node/Cluster Panel ─────────────────────────────────── */
    .nodes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.6rem;
      margin-bottom: 2.5rem;
      padding: 0.35rem 0.25rem;
    }
    .node-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.45) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 12px;
      transition: all 0.3s ease;
    }
    .node-card:hover {
      border-color: rgba(56, 189, 248, 0.25);
      transform: translateY(-2px);
    }
    .node-card header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .node-card h3 {
      margin: 0;
      font-size: 1.15rem;
      font-weight: 700;
      color: #f1f5f9;
    }
    .node-role {
      font-size: 0.8rem;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .node-gauge-row {
      display: grid;
      grid-template-columns: 4rem 1fr 3.5rem;
      gap: 10px;
      align-items: center;
      font-size: 0.82rem;
    }
    .node-gauge-bar {
      width: 100%;
      height: 8px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.72);
      border: 1px solid rgba(255, 255, 255, 0.08);
      overflow: hidden;
    }
    .node-gauge-bar > span {
      display: block;
      height: 100%;
      background: linear-gradient(90deg, #38bdf8, #a78bfa);
    }
    .node-meta {
      font-size: 0.78rem;
      color: #64748b;
      margin-top: 0.35rem;
    }

    /* ── Image Status Grid ──────────────────────────────────── */
    .image-status-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .image-status-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.45) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 18px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .image-status-card h3 {
      margin: 0;
      font-size: 1.1rem;
      font-weight: 700;
      color: #f1f5f9;
    }
    .pulse-stats {
      display: flex;
      gap: 1.5rem;
    }
    .pulse-stat {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .pulse-stat-value {
      font-size: 1.5rem;
      font-weight: 800;
    }
    .pulse-stat-value.tone-good { color: #4ade80; }
    .pulse-stat-value.tone-warn { color: #fbbf24; }
    .pulse-stat-value.tone-bad  { color: #fb7185; }
    .pulse-stat-name {
      font-size: 0.7rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .pulse-stat-detail {
      font-size: 0.68rem;
      color: #94a3b8;
      line-height: 1.25;
      max-width: 12rem;
    }
    .node-links {
      margin-top: 0.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
    }
    .node-link {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      padding: 0.2rem 0.55rem;
      font-size: 0.72rem;
      color: #cbd5e1;
      text-decoration: none;
    }
    .node-link--up {
      border-color: rgba(34, 197, 94, 0.5);
      color: #86efac;
    }
    .node-link--warn {
      border-color: rgba(245, 158, 11, 0.45);
      color: #fcd34d;
    }

    /* ── Fabric SVG overlay ─────────────────────────────────── */
    #cluster-canvas-wrap {
      position: relative;
      padding-top: 2.5rem;
    }
    #fabric-svg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      overflow: visible;
      z-index: 10;
    }

    /* ── Dense Lists ────────────────────────────────────────── */
    .lists-split {
      display: grid;
      grid-template-columns: 1.3fr 0.7fr;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    @media (max-width: 900px) {
      .lists-split {
        grid-template-columns: 1fr;
      }
    }
    .dense-panel {
      background: rgba(15, 23, 42, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
    }
    .dense-panel h2 {
      font-size: 1.25rem;
      font-weight: 800;
      color: #cbd5e1;
      margin: 0 0 1rem 0;
    }
    .dense-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .dense-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 12px;
      background: rgba(30, 41, 59, 0.25);
