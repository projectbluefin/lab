      font-size: 0.75rem;
      color: #64748b;
    }

    /* ── Shell element keeps matching tests ─────────────────── */
    #factory-dashboard {
      display: block;
    }

    @keyframes sizzle {
      0% { filter: brightness(1.0); box-shadow: 0 0 2px rgba(244, 63, 94, 0.4); }
      50% { filter: brightness(1.2); box-shadow: 0 0 8px rgba(249, 115, 22, 0.6); }
      100% { filter: brightness(1.0); box-shadow: 0 0 2px rgba(244, 63, 94, 0.4); }
    }
    .heat-bar-container {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.05);
