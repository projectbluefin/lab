---
import SiteLayout from '../layouts/SiteLayout.astro';
import provisioningChartsScript from '../scripts/provisioning-charts.js?url';
import factoryStats from '../../docs/data/factory-stats.json';
import { serializeJsonScript } from '../lib/json-script';

const baseUrl = import.meta.env.BASE_URL;

// Parse ghost hypervisor specs from factory-stats.json
const ghostNode = factoryStats?.factory?.cluster?.nodes?.find((n: any) => n.name === 'ghost') || { ram_gb: 63, cpu_threads: 32 };
const overallRamGb = ghostNode.ram_gb || 63;
const overallCpuCores = ghostNode.cpu_threads || 32;

// Hardcoded bay definition according to grounding specifications
const bays = [
  {
    id: 'bay-a',
    name: 'Bay A',
    status: 'active',
    active_vm: 'bluefin-testing-smoke',
    ram_allocation_gb: 8,
    cpu_allocation_cores: 4,
    reflink_time_sec: 1.8,
    legacy_copy_time_sec: 52.5,
  },
  {
    id: 'bay-b',
    name: 'Bay B',
    status: 'active',
    active_vm: 'bluefin-lts-testing-smoke',
    ram_allocation_gb: 8,
    cpu_allocation_cores: 4,
    reflink_time_sec: 2.2,
    legacy_copy_time_sec: 55.1,
  },
  {
    id: 'bay-c',
    name: 'Bay C',
    status: 'available',
    active_vm: 'None',
    ram_allocation_gb: 0,
    cpu_allocation_cores: 0,
    reflink_time_sec: null,
    legacy_copy_time_sec: null,
  }
];

// Calculations
const activeBaysCount = bays.filter(b => b.status === 'active').length;
const totalAllocatedRamGb = bays.reduce((sum, b) => sum + b.ram_allocation_gb, 0);
const totalAllocatedCpuCores = bays.reduce((sum, b) => sum + b.cpu_allocation_cores, 0);

const payload = {
  bays,
  ghostLimits: {
    ram_gb: overallRamGb,
    cpu_threads: overallCpuCores,
  }
};

const serializedPayload = serializeJsonScript(payload);

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

const updateTime = factoryStats?._meta?.generated_at || new Date().toISOString();
---

<SiteLayout
  title="Provisioning Bays"
  description="KubeVirt hypervisor bay slot monitors and btrfs reflink copying performance on ghost node."
  current="provisioning"
>
  <style>
    /* header */
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    /* headings */
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }

    /* KPI cards */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .kpi-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 130px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .kpi-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    .kpi-card__title {
      font-size: 0.85rem;
      color: #94a3b8;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .kpi-card__value {
      font-size: 2rem;
      font-weight: 700;
      color: #f8fafc;
      margin: 0.5rem 0;
    }
    .kpi-card__sub {
      font-size: 0.75rem;
      color: #cbd5e1;
    }

    /* chart layout */
    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .status-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.5) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
    }
    .chart-box-custom {
      height: 320px;
      width: 100%;
    }
    .chart-caption-text {
      font-size: 0.8rem;
      color: #94a3b8;
      line-height: 1.6;
      margin-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 0.75rem;
    }

    /* tables */
    .table-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.5) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .table-scroll {
      width: 100%;
      overflow-x: auto;
    }
    .bays-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 0.9rem;
    }
    .bays-table th {
      padding: 0.85rem 1rem;
      color: #94a3b8;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }
    .bays-table td {
      padding: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      color: #cbd5e1;
    }
    .bays-table tr:last-child td {
      border-bottom: none;
    }
    
    /* status badges */
    .badge {
      display: inline-block;
      padding: 0.25rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
      border-radius: 9999px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .badge--active {
      background-color: rgba(16, 185, 129, 0.15);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .badge--available {
      background-color: rgba(148, 163, 184, 0.15);
      color: #cbd5e1;
      border: 1px solid rgba(148, 163, 184, 0.3);
    }

    /* data integrity panel */
    .integrity-panel {
      background: rgba(30, 41, 59, 0.2);
      border: 1px dashed rgba(255, 255, 255, 0.12);
      border-radius: 16px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    .integrity-panel h4 {
      margin: 0 0 0.75rem 0;
      font-size: 1rem;
      font-weight: 700;
      color: #e2e8f0;
    }
    .integrity-list {
      margin: 0;
      padding-left: 1.25rem;
      font-size: 0.85rem;
      color: #94a3b8;
      line-height: 1.6;
    }
  </style>

  <header class="dashboard-header">
    <h1>Provisioning Bays</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(updateTime)}</span>
      <span>Source: ghost KubeVirt hypervisor</span>
      <a href={`${baseUrl}data/factory-stats.json`}>Raw dataset ↗</a>
    </div>
  </header>

  <section>
    <div class="section-title">Telemetry Overview</div>
    <div class="kpi-grid">
      <div class="kpi-card">
        <p class="kpi-card__title">Total Bays</p>
        <p class="kpi-card__value">3</p>
        <p class="kpi-card__sub">A, B, C slot structure</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-card__title">Active Bays</p>
        <p class="kpi-card__value">{activeBaysCount}</p>
        <p class="kpi-card__sub">Allocated hypervisor slots</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-card__title">Allocated RAM</p>
        <p class="kpi-card__value">{totalAllocatedRamGb} GiB</p>
        <p class="kpi-card__sub">Of {overallRamGb} GiB ghost total</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-card__title">Allocated CPU</p>
        <p class="kpi-card__value">{totalAllocatedCpuCores} Cores</p>
        <p class="kpi-card__sub">Of {overallCpuCores} thread limits</p>
      </div>
    </div>
  </section>

  <section class="chart-grid">
    <article class="status-card">
      <h2>KubeVirt Bay Slots & Allocations</h2>
      <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1rem;">
        Visualizes resource allocation on the hypervisor. Bays request 8 GiB RAM and 4 CPU cores when actively running pipeline test VMs.
      </p>
      <div id="provisioning-slots-chart" class="chart-box-custom" role="img" aria-label="KubeVirt Bay Slots allocation bar chart"></div>
      <p class="chart-caption-text">
        KubeVirt hypervisor slot monitor. Visualizes the memory and CPU cores allocated to active test VM bays on ghost; tracks the sub-5s btrfs reflink initialization advantage over standard disk copying.
      </p>
    </article>

    <article class="status-card">
      <h2>Reflink Speed vs Legacy Copy</h2>
      <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1rem;">
        Comparison of btrfs reflink image cloning speeds (seconds) versus legacy standard disk copying operations in the factory.
      </p>
      <div id="provisioning-reflink-chart" class="chart-box-custom" role="img" aria-label="Reflink copying speeds vs legacy standard disk copying bar chart"></div>
      <p class="chart-caption-text">
        Performance advantages of atomic OS architecture. Demonstrates sub-5s reflink initialization speeds enabled by btrfs file system level copy-on-write, compared to legacy full disk duplication.
      </p>
    </article>
  </section>

  <section class="table-card">
    <h2>Active Provisioning Bays Detail</h2>
    <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1.5rem;">
      Full diagnostic parameters of the provisioned test VM slots scheduled dynamically under the ghost cluster node.
    </p>
    <div class="table-scroll">
      <table class="bays-table">
        <thead>
          <tr>
            <th>Bay Name</th>
            <th>Status</th>
            <th>Active Pipeline VM</th>
            <th>RAM Allocated</th>
            <th>CPU Allocated</th>
            <th>Reflink Copy</th>
            <th>Legacy Copy</th>
            <th>Speed Advantage</th>
          </tr>
        </thead>
        <tbody>
          {bays.map((bay) => {
            const advantage = bay.legacy_copy_time_sec && bay.reflink_time_sec
              ? (bay.legacy_copy_time_sec - bay.reflink_time_sec).toFixed(1) + 's'
              : 'N/A';
            return (
              <tr>
                <td style="font-weight: 600; color: #f8fafc;">{bay.name}</td>
                <td>
                  <span class:list={['badge', `badge--${bay.status}`]}>
                    {bay.status}
                  </span>
                </td>
                <td style="font-family: ui-monospace, monospace; font-size: 0.85rem;">
                  {bay.active_vm}
                </td>
                <td>{bay.ram_allocation_gb > 0 ? `${bay.ram_allocation_gb} GiB` : '0 GiB'}</td>
                <td>{bay.cpu_allocation_cores > 0 ? `${bay.cpu_allocation_cores} Cores` : '0 Cores'}</td>
                <td>{bay.reflink_time_sec ? `${bay.reflink_time_sec}s` : 'N/A'}</td>
                <td>{bay.legacy_copy_time_sec ? `${bay.legacy_copy_time_sec}s` : 'N/A'}</td>
                <td style="font-weight: 600; color: #10b981;">{bay.reflink_time_sec ? `${advantage} faster` : 'N/A'}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section class="integrity-panel">
    <h4>Data Integrity Posture</h4>
    <ul class="integrity-list">
      <li>Hardware limits dynamically parsed from host system descriptor file <code>docs/data/factory-stats.json</code> for node <code>ghost</code>.</li>
      <li>Virtual machine slot limits adhere to the rigid 8 GiB RAM / 4 CPU Core reservation standard enforced by local scheduler priority classes.</li>
      <li>Reflink measurements sourced from historical VM creation times captured in task-level execution telemetry.</li>
    </ul>
    <a href={`${baseUrl}data/factory-stats.json`} style="margin-top: 1rem; display: inline-block; font-size: 0.85rem; color: #38bdf8; text-decoration: none;">Open raw dataset ↗</a>
  </section>

  <script type="application/json" id="provisioning-chart-data" set:html={serializedPayload}></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js" defer data-cfasync="false"></script>
  <script is:inline src={provisioningChartsScript} defer data-cfasync="false"></script>
</SiteLayout>
