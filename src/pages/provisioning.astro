---
import { execSync } from 'node:child_process';
import SiteLayout from '../layouts/SiteLayout.astro';
import { serializeJsonScript } from '../lib/json-script';
import factoryStats from '../../docs/data/factory-stats.json';

const baseUrl = import.meta.env.BASE_URL;

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

interface RegistryTags {
  tags: string[];
  name: string;
}

interface SkopeoData {
  Digest?: string;
  Created?: string;
  LayersData?: Array<{ Size: number }>;
  Architecture?: string;
  Os?: string;
}

interface ContainerDiskDef {
  repo: string;
  tags: string[];
  label: string;
  upstream: string;
  filesystem: 'btrfs' | 'xfs' | 'ext4';
  notes?: string;
}

// Canonical containerDisk images consumed by the lab pipelines.
// bluefin-containerdisk is produced by build-containerdisk from bootc images.
// Flatcar containerDisk is produced by provision-flatcar-vm.prepare-flatcar-disk.
const containerDiskCatalog: ContainerDiskDef[] = [
  {
    repo: 'bluefin-containerdisk',
    tags: ['testing', 'lts-testing', 'stable', 'lts-stable'],
    label: 'Bluefin',
    upstream: 'ghcr.io/projectbluefin/bluefin',
    filesystem: 'btrfs',
    notes: 'LTS tags are formatted xfs by bootc install-to-disk; non-LTS tags use btrfs.',
  },
  {
    repo: 'flatcar-containerdisk',
    tags: ['latest'],
    label: 'Flatcar',
    upstream: 'stable.release.flatcar-linux.net',
    filesystem: 'ext4',
    notes: 'Official Flatcar QEMU image wrapped as a containerDisk.',
  },
];

// Query the local Zot registry for tags; fall back to the catalog definition
// when ghost is unreachable so static builds still succeed offline.
const queryTags = (repo: string): string[] => {
  try {
    const res = execSync(`curl -s --max-time 1.5 http://192.168.1.102:30500/v2/${repo}/tags/list`, {
      encoding: 'utf8',
      stdio: ['pipe', 'pipe', 'ignore'],
    });
    const data = JSON.parse(res) as RegistryTags;
    return Array.isArray(data.tags) ? data.tags : [];
  } catch {
    return containerDiskCatalog.find((c) => c.repo === repo)?.tags || [];
  }
};

const inspectRepo = (repo: string, tag: string): SkopeoData | null => {
  try {
    const raw = execSync(`skopeo inspect --tls-verify=false docker://192.168.1.102:30500/${repo}:${tag}`, {
      encoding: 'utf8',
      stdio: ['pipe', 'pipe', 'ignore'],
      timeout: 2000,
    });
    return JSON.parse(raw) as SkopeoData;
  } catch {
    return null;
  }
};

const nodes = Array.isArray(factoryStats?.factory?.cluster?.nodes)
  ? factoryStats.factory.cluster.nodes
  : [];

const cdStats = factoryStats?.pipelines?.containerdisk || { runs_7d: 0, runs_all_time: 0 };
const buildHistory = Array.isArray(factoryStats?.build_history?.['build-containerdisk'])
  ? factoryStats.build_history['build-containerdisk']
  : [];

const containerdisks = containerDiskCatalog.flatMap((def) =>
  def.tags.map((tag) => {
    const liveTags = queryTags(def.repo);
    const live = liveTags.includes(tag);
    const data = live ? inspectRepo(def.repo, tag) : null;
    const sizeBytes = data?.LayersData?.reduce((sum, l) => sum + (l.Size || 0), 0) || 0;
    const sizeMb = sizeBytes > 0 ? (sizeBytes / 1024 / 1024).toFixed(1) : null;
    const isLts = tag.startsWith('lts');
    return {
      repo: def.repo,
      tag,
      label: def.label,
      upstream: def.upstream,
      filesystem: def.repo === 'bluefin-containerdisk' && isLts ? 'xfs' : def.filesystem,
      status: live ? 'available' : 'unavailable',
      digest: data?.Digest || null,
      size_mb: sizeMb,
      created: data?.Created || null,
      arch: data?.Architecture || 'amd64',
      os: data?.Os || 'linux',
      notes: def.notes,
    };
  })
);

const totalRamGb = nodes.reduce((sum, n) => sum + (n.ram_gb || 0), 0);
const totalCpuThreads = nodes.reduce((sum, n) => sum + (n.cpu_threads || 0), 0);

const payload = {
  nodes,
  containerdisks,
  containerdiskBuilds: cdStats,
  recentBuilds: buildHistory.slice(0, 10),
  totals: {
    ram_gb: totalRamGb,
    cpu_threads: totalCpuThreads,
  },
  updatedAt: factoryStats?._meta?.generated_at || new Date().toISOString(),
  dataSource: 'docs/data/factory-stats.json + live Zot registry',
};

const serializedPayload = serializeJsonScript(payload);
const updateTime = payload.updatedAt;
---

<SiteLayout
  title="VM Provisioning"
  description="KubeVirt containerDisk provisioning architecture, hypervisor capacity, and guest filesystem layout for the Bluefin factory."
  current="provisioning"
>
  <style>
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .kpi-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 130px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .kpi-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    .kpi-card__title {
      font-size: 0.85rem;
      color: #94a3b8;
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .kpi-card__value {
      font-size: 2rem;
      font-weight: 700;
      color: #f8fafc;
      margin: 0.5rem 0;
    }
    .kpi-card__sub {
      font-size: 0.75rem;
      color: #cbd5e1;
    }

    .chart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .status-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.5) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
    }
    .status-card h2 {
      margin: 0 0 0.5rem 0;
      font-size: 1.25rem;
      color: #f8fafc;
    }
    .chart-box-custom {
      height: 320px;
      width: 100%;
    }
    .chart-caption-text {
      font-size: 0.8rem;
      color: #94a3b8;
      line-height: 1.6;
      margin-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 0.75rem;
    }

    .info-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.5) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .info-card h2 {
      margin: 0 0 1rem 0;
      font-size: 1.25rem;
      color: #f8fafc;
    }
    .info-card p {
      font-size: 0.9rem;
      color: #cbd5e1;
      line-height: 1.7;
      margin: 0 0 1rem 0;
    }
    .info-card ul {
      margin: 0;
      padding-left: 1.25rem;
      font-size: 0.9rem;
      color: #cbd5e1;
      line-height: 1.7;
    }
    .info-card li { margin-bottom: 0.5rem; }
    .info-card code {
      background: rgba(15, 23, 42, 0.5);
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      font-size: 0.85rem;
      color: #38bdf8;
    }

    .table-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.3) 0%, rgba(15, 23, 42, 0.5) 100%);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 20px;
      padding: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .table-card h2 {
      margin: 0 0 0.5rem 0;
      font-size: 1.25rem;
      color: #f8fafc;
    }
    .table-scroll {
      width: 100%;
      overflow-x: auto;
    }
    .data-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 0.9rem;
    }
    .data-table th {
      padding: 0.85rem 1rem;
      color: #94a3b8;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }
    .data-table td {
      padding: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      color: #cbd5e1;
    }
    .data-table tr:last-child td { border-bottom: none; }

    .badge {
      display: inline-block;
      padding: 0.25rem 0.6rem;
      font-size: 0.75rem;
      font-weight: 600;
      border-radius: 9999px;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .badge--available {
      background-color: rgba(16, 185, 129, 0.15);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.3);
    }
    .badge--unavailable {
      background-color: rgba(148, 163, 184, 0.15);
      color: #cbd5e1;
      border: 1px solid rgba(148, 163, 184, 0.3);
    }
    .badge--ready {
      background-color: rgba(56, 189, 248, 0.15);
      color: #38bdf8;
      border: 1px solid rgba(56, 189, 248, 0.3);
    }

    .filesystem-btrfs { color: #34d399; }
    .filesystem-xfs { color: #fbbf24; }
    .filesystem-ext4 { color: #a78bfa; }

    .integrity-panel {
      background: rgba(30, 41, 59, 0.2);
      border: 1px dashed rgba(255, 255, 255, 0.12);
      border-radius: 16px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    .integrity-panel h4 {
      margin: 0 0 0.75rem 0;
      font-size: 1rem;
      font-weight: 700;
      color: #e2e8f0;
    }
    .integrity-list {
      margin: 0;
      padding-left: 1.25rem;
      font-size: 0.85rem;
      color: #94a3b8;
      line-height: 1.6;
    }

    .mono { font-family: ui-monospace, monospace; font-size: 0.85rem; }
  </style>

  <header class="dashboard-header">
    <h1>VM Provisioning</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(updateTime)}</span>
      <span>Source: {payload.dataSource}</span>
      <a href={`${baseUrl}data/factory-stats.json`}>Raw dataset</a>
    </div>
  </header>

  <section class="info-card">
    <h2>Provisioning Architecture</h2>
    <p>
      Test VMs boot from OCI <strong>containerDisk</strong> images stored in the local Zot registry
      (<code>192.168.1.102:30500</code>). Each pipeline run pulls the disk image and launches a fresh
      KubeVirt VM. The VM is torn down on exit. This replaces the older golden-disk hostDisk workflow
      that relied on btrfs reflink copies on the ghost node.
    </p>
    <ul>
      <li>
        <strong>No host-side btrfs reflink:</strong> The hypervisor does not keep a raw golden disk
        tree that is reflink-copied per VM. Disks are distributed as compressed OCI layers and
        unpacked by containerd at runtime.
      </li>
      <li>
        <strong>Guest filesystems vary by variant:</strong> Bluefin non-LTS uses btrfs; Bluefin LTS
        uses xfs; Flatcar uses ext4. The filesystem is chosen by the upstream image, not by the
        provisioning layer.
      </li>
      <li>
        <strong>VMs float across nodes:</strong> ContainerDisk VMs schedule on any KubeVirt-capable
        node. PVC-backed lanes (Knuckle) co-schedule on the node that owns the PVC.
      </li>
      <li>
        <strong>SSH keys are injected at runtime:</strong> KubeVirt accessCredentials propagate the
        public key via the QEMU guest agent after boot. No key material is baked into the published
        disk image.
      </li>
    </ul>
  </section>

  <section>
    <div class="section-title">Fleet Overview</div>
    <div class="kpi-grid">
      <div class="kpi-card">
        <p class="kpi-card__title">Hypervisor Nodes</p>
        <p class="kpi-card__value">{nodes.length}</p>
        <p class="kpi-card__sub">KubeVirt-capable cluster members</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-card__title">Cluster RAM</p>
        <p class="kpi-card__value">{totalRamGb} GiB</p>
        <p class="kpi-card__sub">Total allocatable memory</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-card__title">Cluster CPU</p>
        <p class="kpi-card__value">{totalCpuThreads} Threads</p>
        <p class="kpi-card__sub">Total allocatable threads</p>
      </div>
      <div class="kpi-card">
        <p class="kpi-card__title">ContainerDisk Builds (7d)</p>
        <p class="kpi-card__value">{cdStats.runs_7d}</p>
        <p class="kpi-card__sub">{cdStats.runs_all_time} builds all-time</p>
      </div>
    </div>
  </section>

  <section class="chart-grid">
    <article class="status-card">
      <h2>Hypervisor Capacity</h2>
      <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1rem;">
        Installed RAM and CPU threads per KubeVirt-capable node. Actual VM packing is constrained by
        k8s scheduler requests and the <code>qa-vm-fleet</code> template semaphore.
      </p>
      <div id="provisioning-capacity-chart" class="chart-box-custom" role="img" aria-label="Hypervisor capacity bar chart"></div>
      <p class="chart-caption-text">
        Cluster aggregate capacity derived from docs/data/factory-stats.json factory.cluster.nodes.
      </p>
    </article>

    <article class="status-card">
      <h2>Guest Filesystems</h2>
      <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1rem;">
        Distribution of root filesystems across the published containerDisk catalog. Values reflect
        the filesystem selected by bootc install-to-disk or the upstream image, not the host format.
      </p>
      <div id="provisioning-filesystems-chart" class="chart-box-custom" role="img" aria-label="Guest filesystem distribution donut chart"></div>
      <p class="chart-caption-text">
        Filesystem mapping sourced from argo/workflow-templates/build-containerdisk.yaml and
        provision-flatcar-vm.yaml.
      </p>
    </article>
  </section>

  <section class="table-card">
    <h2>ContainerDisk Inventory</h2>
    <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1.5rem;">
      Published VM boot images in the local Zot registry. Sizes are OCI layer sizes; the raw disk
      unpacked inside the virt-launcher pod is larger.
    </p>
    <div class="table-scroll">
      <table class="data-table">
        <thead>
          <tr>
            <th>Image</th>
            <th>Tag</th>
            <th>Status</th>
            <th>Guest FS</th>
            <th>Size</th>
            <th>Digest</th>
            <th>Created</th>
          </tr>
        </thead>
        <tbody>
          {containerdisks.map((cd) => (
            <tr>
              <td style="font-weight: 600; color: #f8fafc;">{cd.label}</td>
              <td class="mono">{cd.tag}</td>
              <td>
                <span class:list={['badge', `badge--${cd.status}`]}>
                  {cd.status}
                </span>
              </td>
              <td class:list={[`filesystem-${cd.filesystem}`]} style="font-weight: 600; text-transform: uppercase;">
                {cd.filesystem}
              </td>
              <td>{cd.size_mb ? `${cd.size_mb} MB` : 'N/A'}</td>
              <td class="mono">{cd.digest ? cd.digest.slice(0, 19) + '...' : 'N/A'}</td>
              <td>{cd.created ? formatUtc(cd.created) : 'N/A'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="table-card">
    <h2>Hypervisor Nodes</h2>
    <p style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 1.5rem;">
      KubeVirt-capable cluster nodes that can schedule test VM workloads.
    </p>
    <div class="table-scroll">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Role</th>
            <th>Status</th>
            <th>OS</th>
            <th>Kernel</th>
            <th>RAM</th>
            <th>CPU Threads</th>
            <th>Memory Use</th>
            <th>CPU Use</th>
          </tr>
        </thead>
        <tbody>
          {nodes.map((node) => (
            <tr>
              <td style="font-weight: 600; color: #f8fafc;">{node.name}</td>
              <td>{node.role}</td>
              <td>
                <span class:list={['badge', `badge--${node.status}`]}>
                  {node.status}
                </span>
              </td>
              <td>{node.os_image}</td>
              <td class="mono">{node.kernel_version}</td>
              <td>{node.ram_gb} GiB</td>
              <td>{node.cpu_threads}</td>
              <td>{node.mem_usage_pct}%</td>
              <td>{node.cpu_usage_pct}%</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="integrity-panel">
    <h4>Data Integrity Posture</h4>
    <ul class="integrity-list">
      <li>
        Node capacity, utilization, and containerDisk build counts are read from
        <code>docs/data/factory-stats.json</code>.
      </li>
      <li>
        ContainerDisk availability, digest, size, and creation time are queried live from the local
        Zot registry at build time; when ghost is unreachable the page falls back to the catalog
        definition and marks the disk unavailable.
      </li>
      <li>
        Guest filesystem labels are derived from the bootc install-to-disk logic in
        argo/workflow-templates/build-containerdisk.yaml and are not inferred from disk names.
      </li>
    </ul>
    <a href={`${baseUrl}data/factory-stats.json`} style="margin-top: 1rem; display: inline-block; font-size: 0.85rem; color: #38bdf8; text-decoration: none;">Open raw dataset</a>
  </section>

  <script type="application/json" id="provisioning-chart-data" set:html={serializedPayload}></script>
  <script>
    import '../scripts/provisioning-charts.js';
  </script>
</SiteLayout>
