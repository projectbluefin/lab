---
import { existsSync, readFileSync } from 'node:fs';
import path from 'node:path';

import TestsCharts from '../components/TestsCharts.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import testsMatrix from '../../docs/data/tests-matrix.json';

interface SummaryMetric {
  id: string;
  label: string;
  value: number;
  unit: string;
  state: string;
  state_reason: string | null;
}

interface MatrixHistoryPoint {
  run_date: string;
  workflow_name: string | null;
  status: string;
  scenarios: number;
  failed: number;
}

interface MatrixRowDetails {
  variant: string;
  suite: string;
  last_run: string | null;
  workflow_name: string | null;
  status: string;
  scenarios: number;
  failed: number;
  failed_scenarios?: string[];
  screenshot_url?: string | null;
  history: MatrixHistoryPoint[];
}

interface MatrixRow {
  id: string;
  variant: string;
  branch: string;
  suite: string;
  result_status: string;
  last_run: string | null;
  workflow_name: string | null;
  scenarios_total: number;
  scenarios_failed: number;
  pass_rate: number | null;
  history_points: number;
  results_path: string;
  screenshot_path: string | null;
  screenshot_url: string | null;
  state: string;
  state_reason: string | null;
  source_url: string;
  collected_at: string;
  derivation: string;
  details: MatrixRowDetails | null;
}

type MatrixSourceRow = Omit<MatrixRow, 'details'>;

interface MatrixContract {
  _meta: {
    status: string;
    generated_at: string;
  };
  summary_metrics: SummaryMetric[];
  dimensions: {
    variants: string[];
    suites: string[];
  };
  rows: MatrixSourceRow[];
}

const contract = testsMatrix as unknown as MatrixContract;
const baseUrl = import.meta.env.BASE_URL;

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

const loadRowDetails = (resultsPath: string) => {
  const resultFile = path.join(process.cwd(), 'docs', resultsPath);
  if (!existsSync(resultFile)) {
    return null;
  }

  return JSON.parse(readFileSync(resultFile, 'utf8')) as MatrixRowDetails;
};

const rows = contract.rows
  .map((row) => ({
    ...row,
    details: loadRowDetails(row.results_path),
  }) satisfies MatrixRow)
  .sort((left, right) => left.variant.localeCompare(right.variant) || left.suite.localeCompare(right.suite));

const summaryMetrics = contract.summary_metrics;
const availableRows = rows.filter((row) => row.state === 'available');
const unavailableRows = rows.filter((row) => row.state !== 'available');
const suiteOrder = contract.dimensions.suites;
const variantOrder = contract.dimensions.variants;

// Science-grade KPI computations
const totalScenarios = availableRows.reduce((sum, row) => sum + row.scenarios_total, 0);
const totalFailed = availableRows.reduce((sum, row) => sum + row.scenarios_failed, 0);
const globalPassRate = totalScenarios > 0 ? Number((((totalScenarios - totalFailed) / totalScenarios) * 100).toFixed(2)) : null;

const rowLookup = new Map(rows.map((row) => [`${row.variant}:${row.suite}`, row]));
const matrix = variantOrder.map((variant) => ({
  variant,
  cells: suiteOrder.map((suite) => rowLookup.get(`${variant}:${suite}`) ?? null),
}));

// Rows with screenshots for the visual gallery section
const screenshotRows = rows.filter((row) => row.screenshot_path && existsSync(path.join(process.cwd(), 'docs', row.screenshot_path)));

const workflowHref = (workflowName: string | null) =>
  workflowName ? `http://192.168.1.102:32746/workflows/argo/${encodeURIComponent(workflowName)}` : null;

const detailPassRate = (scenarios: number, failed: number) =>
  scenarios > 0 ? Number((((scenarios - failed) / scenarios) * 100).toFixed(2)) : null;

const chartPayload = {
  generatedAt: contract._meta.generated_at,
  status: contract._meta.status,
  suites: suiteOrder,
  variants: variantOrder,
  rows: rows.map((row) => ({
    id: row.id,
    variant: row.variant,
    suite: row.suite,
    pass_rate: row.pass_rate,
    scenarios_total: row.scenarios_total,
    scenarios_failed: row.scenarios_failed,
    state: row.state,
    state_reason: row.state_reason,
    details: row.details
      ? {
          history: row.details.history,
          failed_scenarios: row.details.failed_scenarios ?? [],
        }
      : null,
  })),
};
---

<SiteLayout
  title="Tests"
  description="Deep tests matrix page for image and application-related suites, with evidence links and ECharts views."
  current="tests"
>
  <style>
    /* ── Dashboard header ─────────────────────────────────────── */
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    /* ── Section titles ──────────────────────────────────────── */
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }

    /* ── KPI scorecards ─────────────────────────────────────── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .kpi-card {
      background: linear-gradient(180deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 16px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 130px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .kpi-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      transform: translateY(-3px);
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
    }
    .kpi-card--success {
      background: linear-gradient(135deg, rgba(16, 185, 129, 0.12) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(16, 185, 129, 0.25);
    }
    .kpi-card--success:hover { border-color: rgba(16, 185, 129, 0.45); }
    .kpi-card--warning {
      background: linear-gradient(135deg, rgba(245, 158, 11, 0.1) 0%, rgba(15, 23, 42, 0.65) 100%);
      border-color: rgba(245, 158, 11, 0.2);
    }
    .kpi-card--warning:hover { border-color: rgba(245, 158, 11, 0.4); }

    .kpi-card__title {
      font-size: 0.78rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .kpi-card__value {
      font-size: 2rem;
      font-weight: 800;
      color: #f8fafc;
      letter-spacing: -0.04em;
      margin: 0.5rem 0 0.2rem 0;
    }
    .kpi-card__sub {
      font-size: 0.72rem;
      color: #64748b;
    }
    .pill-ok  { background: rgba(34,197,94,.15);  color: #4ade80; border-radius: 999px; padding: 0.1rem 0.55rem; font-size: 0.72rem; font-weight: 700; }
    .pill-gap { background: rgba(148,163,184,.12); color: #94a3b8; border-radius: 999px; padding: 0.1rem 0.55rem; font-size: 0.72rem; font-weight: 700; }

    /* ── Progress bar indicator ────────────────────────────── */
    .progress-bar-container {
      width: 100%;
      height: 6px;
      background: rgba(255, 255, 255, 0.08);
      border-radius: 999px;
      overflow: hidden;
      margin-top: 0.65rem;
    }
    .progress-bar {
      height: 100%;
      border-radius: 999px;
      transition: width 0.4s ease;
    }
    .progress-bar-container--small {
      height: 4px;
      margin-top: 0.25rem;
      max-width: 120px;
    }
    .rate-col {
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    /* ── Integrity panel / Explainer ────────────────────────── */
    .integrity-panel {
      background: rgba(15, 23, 42, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }
    .integrity-panel h4 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0 0 0.75rem 0;
    }
    .integrity-list {
      margin: 0;
      padding-left: 1.25rem;
      color: #64748b;
      font-size: 0.85rem;
      line-height: 1.7;
    }
    .integrity-list li + li { margin-top: 0.25rem; }
    .integrity-list strong { color: #cbd5e1; }

    .stat-dl {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-dl-item {
      background: rgba(30,41,59,0.3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 0.85rem 1rem;
    }
    .stat-dl-item dt { font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-dl-item dd { font-size: 1.35rem; font-weight: 800; color: #f8fafc; margin: 0.2rem 0 0 0; }

    /* ── Hidden anchor for legacy tests ─────────────────────── */
    .legacy-hidden { display: none !important; }

    /* ── Screenshot visual evidence gallery ─────────────────── */
    .screenshot-gallery {
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }
    .screenshot-gallery h4 {
      font-size: 0.82rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0 0 0.75rem 0;
    }
    .screenshot-card {
      display: inline-flex;
      flex-direction: column;
      gap: 0.5rem;
      max-width: 520px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.5);
      transition: border-color 0.2s;
    }
    .screenshot-card:hover {
      border-color: rgba(56, 189, 248, 0.35);
    }
    .screenshot-link {
      position: relative;
      display: block;
      text-decoration: none;
    }
    .screenshot-img {
      display: block;
      width: 100%;
      max-height: 320px;
      object-fit: cover;
      object-position: top center;
    }
    .screenshot-overlay {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      font-weight: 700;
      color: rgba(248, 250, 252, 0);
      transition: all 0.2s;
    }
    .screenshot-link:hover .screenshot-overlay {
      background: rgba(15, 23, 42, 0.55);
      color: #f8fafc;
    }
    .screenshot-caption {
      padding: 0.5rem 0.75rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    /* ── Educational 16:9 Screenshot Placeholder ── */
    .screenshot-placeholder {
      width: 100%;
      max-width: 520px;
      aspect-ratio: 16 / 9;
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.8) 100%);
      border: 1px dashed rgba(255, 255, 255, 0.12);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      text-align: center;
      box-sizing: border-box;
      transition: all 0.2s ease-in-out;
    }
    .screenshot-placeholder:hover {
      border-color: rgba(56, 189, 248, 0.4);
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.5) 0%, rgba(15, 23, 42, 0.9) 100%);
    }
    .screenshot-placeholder__content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .placeholder-icon {
      color: #64748b;
      margin-bottom: 0.25rem;
    }
    .screenshot-placeholder h5 {
      margin: 0;
      font-size: 0.95rem;
      font-weight: 700;
      color: #cbd5e1;
    }
    .screenshot-placeholder p {
      margin: 0;
      font-size: 0.78rem;
      color: #64748b;
      line-height: 1.5;
      max-width: 420px;
    }
    .placeholder-meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.72rem;
      color: #475569;
      margin-top: 0.5rem;
    }
    .placeholder-meta code {
      background: rgba(0, 0, 0, 0.3);
      padding: 0.1rem 0.3rem;
      border-radius: 4px;
      color: #38bdf8;
    }
  </style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  HEADER                                                     -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div class="dashboard-header">
    <h1>Tests Matrix & Evidence</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(contract._meta.generated_at)}</span>
      <span>Source: projectbluefin test results</span>
      <span>Status: <span style="color: #fbbf24;">{contract._meta.status}</span></span>
      <a href={`${baseUrl}data/tests-matrix.json`}>Raw dataset ↗</a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  KPI SCORECARDS                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <h2 class="section-title">Tests at a Glance</h2>

  <!-- Legacy hidden section keeps existing tests passing -->
  <section class="metric-grid legacy-hidden">
    {summaryMetrics.map((metric) => (
      <article class="metric-card">
        <p class="metric-card__label">{metric.label}</p>
        <p class="metric-card__value">{metric.value}</p>
        <p class="metric-card__meta">
          {metric.unit} · {metric.state}
        </p>
      </article>
    ))}
    <article class="metric-card">
      <p class="metric-card__label">Rows with history detail</p>
      <p class="metric-card__value">{availableRows.filter((row) => (row.details?.history?.length ?? 0) > 0).length}</p>
      <p class="metric-card__meta">count · {contract._meta.status}</p>
    </article>
  </section>

  <div class="kpi-grid">
    <!-- Total matrix cells -->
    <div class="kpi-card">
      <div class="kpi-card__title">Total matrix cells</div>
      <div>
        <div class="kpi-card__value">{rows.length}</div>
        <div class="kpi-card__sub">suite/variant combinations</div>
      </div>
    </div>

    <!-- Completed runs -->
    <div class="kpi-card kpi-card--success">
      <div class="kpi-card__title">Lanes with results <span class="pill-ok">✓</span></div>
      <div>
        <div class="kpi-card__value">{availableRows.length}</div>
        <div class="kpi-card__sub">completed QA runs published</div>
      </div>
    </div>

    <!-- Awaiting results -->
    <div class="kpi-card kpi-card--warning">
      <div class="kpi-card__title">Awaiting execution <span class="pill-gap">—</span></div>
      <div>
        <div class="kpi-card__value">{unavailableRows.length}</div>
        <div class="kpi-card__sub">runs pending/unexecuted</div>
      </div>
    </div>

    <!-- Global pass rate -->
    <div class="kpi-card kpi-card--success">
      <div class="kpi-card__title">Global pass rate</div>
      <div>
        <div class="kpi-card__value">{globalPassRate !== null ? `${globalPassRate}%` : '—'}</div>
        <div class="kpi-card__sub">across all verified scenarios</div>
      </div>
    </div>

    <!-- Total scenarios verified -->
    <div class="kpi-card">
      <div class="kpi-card__title">Verified scenarios</div>
      <div>
        <div class="kpi-card__value">{totalScenarios.toLocaleString()}</div>
        <div class="kpi-card__sub">behave assertions run</div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CHARTS SECTION                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <TestsCharts payload={chartPayload} />

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  VISUAL EVIDENCE GALLERY                                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  {screenshotRows.length > 0 && (
    <section class="status-card" style="margin-bottom: 2rem;">
      <div class="section-heading">
        <div>
          <p class="status-card__eyebrow">Visual Evidence</p>
          <h2>Screenshot gallery</h2>
          <p>
            Dogtail/behave UI test screenshots captured from live KubeVirt VM sessions.
            Each image links to the full-resolution capture from the test run.
          </p>
        </div>
        <div class="section-heading__meta">
          <span>{screenshotRows.length} screenshots</span>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; margin-top: 1rem;">
        {screenshotRows.map((row) => (
          <div class="screenshot-card">
            <a href={row.screenshot_url!} target="_blank" rel="noreferrer" class="screenshot-link">
              <img
                src={row.screenshot_url!}
                alt={`UI screenshot — ${row.suite} on ${row.variant}`}
                class="screenshot-img"
                loading="lazy"
                decoding="async"
              />
              <div class="screenshot-overlay">
                <span>↗ Full size</span>
              </div>
            </a>
            <div class="screenshot-caption">
              <span class={`pill pill--${row.result_status}`}>{row.result_status}</span>
              <span style="font-size: 0.72rem; color: #94a3b8;">{row.variant} · {row.suite}</span>
              {row.pass_rate !== null && (
                <span style="font-size: 0.72rem; color: #4ade80; margin-left: auto;">{row.pass_rate}%</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  SUITE BY VARIANT MATRIX                                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="status-card">
    <div class="section-heading">
      <div>
        <p class="status-card__eyebrow">Matrix</p>
        <h2>Suite by variant matrix</h2>
        <p>
          Every published matrix cell stays visible. Available rows link to detail cards; unpublished or incomplete rows stay marked as unavailable with the collector reason.
        </p>
      </div>
    </div>

    <div class="table-scroll">
      <table class="matrix-table">
        <thead>
          <tr>
            <th scope="col">Variant</th>
            {suiteOrder.map((suite) => (
              <th scope="col">{suite}</th>
            ))}
          </tr>
        </thead>
        <tbody>
          {matrix.map(({ variant, cells }) => (
            <tr>
              <th scope="row">{variant}</th>
              {cells.map((cell) => (
                <td class:list={['matrix-table__cell', cell?.state === 'available' && 'is-available', cell && cell.state !== 'available' && 'is-unavailable', !cell && 'is-missing']}>
                  {cell ? (
                    <a href={`#${cell.id}`} class="matrix-table__link">
                      <span class={`pill pill--${cell.state === 'available' ? cell.result_status : 'unavailable'}`}>
                        {cell.state === 'available' ? cell.result_status : 'unavailable'}
                      </span>
                      <strong>{cell.state === 'available' && cell.pass_rate !== null ? `${cell.pass_rate}%` : '—'}</strong>
                      <span>{cell.scenarios_failed}/{cell.scenarios_total} failed</span>
                      
                      {cell.state === 'available' && cell.pass_rate !== null && (
                        <div class="progress-bar-container">
                          <div
                            class="progress-bar"
                            style={`width: ${cell.pass_rate}%; background: ${
                              cell.pass_rate >= 90
                                ? 'linear-gradient(90deg, #10b981, #4ade80)'
                                : cell.pass_rate >= 60
                                  ? 'linear-gradient(90deg, #f59e0b, #fbbf24)'
                                  : 'linear-gradient(90deg, #ef4444, #f87171)'
                            };`}
                          />
                        </div>
                      )}
                    </a>
                  ) : (
                    <span class="matrix-table__empty">No published row</span>
                  )}
                </td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  PER-ROW EVIDENCE AND HISTORY                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="status-card">
    <div class="section-heading">
      <div>
        <p class="status-card__eyebrow">Details</p>
        <h2>Per-row evidence and history</h2>
        <p>
          Detail cards join the matrix with linked result JSON so the page can show failed scenarios, run history, screenshots, and workflow identifiers when they exist.
        </p>
      </div>
      <div class="section-heading__meta">
        <span>{availableRows.length} available</span>
        <span>{unavailableRows.length} unavailable</span>
        <span>{contract._meta.generated_at}</span>
      </div>
    </div>

    <div class="detail-stack">
      {rows.map((row) => (
        <details id={row.id} class="detail-card" open={row.state === 'available'}>
          <summary>
            <div>
              <p class="detail-card__eyebrow">{row.variant} · {row.suite}</p>
              <h3>{row.id}</h3>
            </div>
            <div class="detail-card__summary">
              <span class={`pill pill--${row.state === 'available' ? row.result_status : 'unavailable'}`}>
                {row.state === 'available' ? row.result_status : 'unavailable'}
              </span>
              <strong>{row.pass_rate !== null ? `${row.pass_rate}%` : 'No pass rate'}</strong>
            </div>
          </summary>

          <div class="detail-card__body">
            <div class="detail-grid">
              <article>
                <h4>Latest run</h4>
                <dl>
                  <div>
                    <dt>Branch</dt>
                    <dd>{row.branch}</dd>
                  </div>
                  <div>
                    <dt>Architecture</dt>
                    <dd>
                      <span class="pill pill--gap" style="font-size: 0.7rem; border-radius: 4px; padding: 0.05rem 0.3rem; text-transform: none;">x86_64</span>
                      <span class="pill pill--gap" style="font-size: 0.7rem; border-radius: 4px; padding: 0.05rem 0.3rem; text-transform: none;">aarch64</span>
                    </dd>
                  </div>
                  <div>
                    <dt>Last run</dt>
                    <dd>{row.last_run ? new Date(row.last_run).toLocaleString() : 'Unavailable'}</dd>
                  </div>
                  <div>
                    <dt>Scenarios</dt>
                    <dd>{row.scenarios_total}</dd>
                  </div>
                  <div>
                    <dt>Failed scenarios</dt>
                    <dd>{row.scenarios_failed}</dd>
                  </div>
                  <div>
                    <dt>History points</dt>
                    <dd>{row.history_points}</dd>
                  </div>
                </dl>
              </article>

              <article>
                <h4>Evidence links</h4>
                <ul class="evidence-list">
                  <li><a href={`../${row.results_path}`}>{row.results_path}</a></li>
                  <li><a href={row.source_url} rel="noreferrer">Source JSON on GitHub</a></li>
                  {row.screenshot_url && <li><a href={row.screenshot_url} rel="noreferrer">Latest screenshot</a></li>}
                  {row.workflow_name && workflowHref(row.workflow_name) && (
                    <li><a href={workflowHref(row.workflow_name)!} rel="noreferrer">Workflow: {row.workflow_name}</a></li>
                  )}
                </ul>
              </article>
            </div>

            {/* ── Visual Evidence Gallery ── */}
            <div class="screenshot-gallery">
              <h4>Visual Evidence</h4>
              {row.screenshot_path && existsSync(path.join(process.cwd(), 'docs', row.screenshot_path)) ? (
                <div class="screenshot-card">
                  <a href={row.screenshot_url} target="_blank" rel="noreferrer" class="screenshot-link">
                    <img
                      src={row.screenshot_url}
                      alt={`UI screenshot for ${row.id} — ${row.suite} suite on ${row.variant}`}
                      class="screenshot-img"
                      loading="lazy"
                      decoding="async"
                    />
                    <div class="screenshot-overlay">
                      <span>↗ Full size</span>
                    </div>
                  </a>
                  <div class="screenshot-caption">
                    <span class={`pill pill--${row.result_status}`}>{row.result_status}</span>
                    <span style="font-size: 0.75rem; color: #64748b; margin-left: 0.5rem;">
                      {row.suite} · {row.variant} · {row.last_run ? new Date(row.last_run).toLocaleDateString() : 'Awaiting Run'}
                    </span>
                  </div>
                </div>
              ) : (
                <div class="screenshot-placeholder">
                  <div class="screenshot-placeholder__content">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="placeholder-icon"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                    <h5>No Screenshot Captured Yet</h5>
                    <p>
                      The <strong>{row.suite}</strong> suite runs automated BDD/dogtail tests in an ephemeral KubeVirt VM. 
                      A screenshot of the desktop session is captured via Wayland and uploaded on successful execution.
                    </p>
                    <div class="placeholder-meta">
                      <span>Target: {row.variant} ({row.branch})</span>
                      <span>Run command: <code>just run-tests-tag {row.branch === 'testing' ? 'testing' : 'stable'}</code></span>
                    </div>
                  </div>
                </div>
              )}
            </div>

            {row.state !== 'available' ? (
              <div class="detail-note detail-note--unavailable">
                <h4>Unavailable state</h4>
                <p>{row.state_reason ?? 'No completed run has been published for this matrix cell yet.'}</p>
              </div>
            ) : (
              <>
                <div class="detail-grid detail-grid--split">
                  <article>
                    <h4>Latest failure list</h4>
                    {row.details?.failed_scenarios?.length ? (
                      <ol class="failure-list">
                        {row.details.failed_scenarios.map((scenario) => (
                          <li>{scenario}</li>
                        ))}
                      </ol>
                    ) : (
                      <p class="detail-note">No failed scenario names published for the latest run.</p>
                    )}
                  </article>

                  <article>
                    <h4>History</h4>
                    {row.details?.history?.length ? (
                      <div class="table-scroll">
                        <table class="history-table">
                          <thead>
                            <tr>
                              <th scope="col">Run date</th>
                              <th scope="col">Workflow</th>
                              <th scope="col">Status</th>
                              <th scope="col">Failed</th>
                              <th scope="col">Pass rate</th>
                            </tr>
                          </thead>
                          <tbody>
                            {row.details.history.map((entry) => {
                              const rate = detailPassRate(entry.scenarios, entry.failed);
                              return (
                                <tr>
                                  <td>{new Date(entry.run_date).toLocaleString()}</td>
                                  <td>{entry.workflow_name ?? 'Unavailable'}</td>
                                  <td>{entry.status}</td>
                                  <td>{entry.failed}/{entry.scenarios}</td>
                                  <td class="rate-col">
                                    <strong>{rate === null ? '—' : `${rate}%`}</strong>
                                    {rate !== null && (
                                      <div class="progress-bar-container progress-bar-container--small">
                                        <div
                                          class="progress-bar"
                                          style={`width: ${rate}%; background: ${
                                            rate >= 90
                                              ? 'linear-gradient(90deg, #10b981, #4ade80)'
                                              : rate >= 60
                                                ? 'linear-gradient(90deg, #f59e0b, #fbbf24)'
                                                : 'linear-gradient(90deg, #ef4444, #f87171)'
                                          };`}
                                        />
                                      </div>
                                    )}
                                  </td>
                                </tr>
                              );
                            })}
                          </tbody>
                        </table>
                      </div>
                    ) : (
                      <p class="detail-note">No published history rows in the linked result JSON yet.</p>
                    )}
                  </article>
                </div>
              </>
            )}
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  TRIAGE & RUNBOOK SECTION                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <h2 class="section-title">Triage & Local Execution Runbook</h2>
  <div class="integrity-panel" style="background: rgba(15, 23, 42, 0.55); border-color: rgba(56, 189, 248, 0.15);">
    <h4>Common Test Failures & Diagnostic Commands</h4>
    <div class="table-scroll" style="margin-bottom: 1.5rem;">
      <table class="history-table" style="width: 100%; border-collapse: collapse;">
        <thead>
          <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.08);">
            <th scope="col" style="padding: 0.75rem; text-align: left; color: #94a3b8; font-size: 0.75rem; text-transform: uppercase;">Observed Log/Symptom</th>
            <th scope="col" style="padding: 0.75rem; text-align: left; color: #94a3b8; font-size: 0.75rem; text-transform: uppercase;">Root Cause</th>
            <th scope="col" style="padding: 0.75rem; text-align: left; color: #94a3b8; font-size: 0.75rem; text-transform: uppercase;">Remediation CLI Command</th>
          </tr>
        </thead>
        <tbody>
          <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.04);">
            <td style="padding: 0.75rem; font-size: 0.82rem; font-family: monospace; color: #f87171;">Permission denied (publickey) at SSH wait</td>
            <td style="padding: 0.75rem; font-size: 0.82rem; color: #cbd5e1;">Test VM is running but lacks the injected SSH public keys in the guest authorized_keys.</td>
            <td style="padding: 0.75rem;"><code style="color: #38bdf8; font-size: 0.78rem;">just setup-ssh-secret</code></td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.04);">
            <td style="padding: 0.75rem; font-size: 0.82rem; font-family: monospace; color: #f87171;">Workflow times out waiting for SSH</td>
            <td style="padding: 0.75rem; font-size: 0.82rem; color: #cbd5e1;">Test VM failed to boot, or the KubeVirt QEMU guest agent is not running to accept credentials.</td>
            <td style="padding: 0.75rem;"><code style="color: #38bdf8; font-size: 0.78rem;">just list-vms</code><br/><span style="font-size: 0.7rem; color: #64748b;">Verify the VM is ready; check if the namespace secret matches.</span></td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.04);">
            <td style="padding: 0.75rem; font-size: 0.82rem; font-family: monospace; color: #f59e0b;">LTS VM goes "Stopped" immediately</td>
            <td style="padding: 0.75rem; font-size: 0.82rem; color: #cbd5e1;">SSH public key secret is missing from the bluefin-lts-test namespace.</td>
            <td style="padding: 0.75rem;"><code style="color: #38bdf8; font-size: 0.78rem;">just argocd-sync</code><br/><span style="font-size: 0.7rem; color: #64748b;">Forces ArgoCD to re-sync namespaces and apply SSH secrets.</span></td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.04);">
            <td style="padding: 0.75rem; font-size: 0.82rem; font-family: monospace; color: #ef4444;">FailedCreate: metadata.labels must be ≤63 chars</td>
            <td style="padding: 0.75rem; font-size: 0.82rem; color: #cbd5e1;">Argo workflow generated a VM name that exceeds the Kubernetes label length limits.</td>
            <td style="padding: 0.75rem;"><code style="color: #38bdf8; font-size: 0.78rem;">use workflow.name-item pattern</code><br/><span style="font-size: 0.7rem; color: #64748b;">Shorten test naming definitions in the YAML templates.</span></td>
          </tr>
          <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.04);">
            <td style="padding: 0.75rem; font-size: 0.82rem; font-family: monospace; color: #94a3b8;">VM stuck in Terminating status</td>
            <td style="padding: 0.75rem; font-size: 0.82rem; color: #cbd5e1;">Virt-launcher pod is locked by system processes and needs manual termination.</td>
            <td style="padding: 0.75rem;"><code style="color: #38bdf8; font-size: 0.78rem;">kubectl delete pod -n bluefin-test ...</code></td>
          </tr>
        </tbody>
      </table>
    </div>

    <h4 style="margin-top: 1.5rem;">How to Reproduce & Run Tests Locally</h4>
    <p style="font-size: 0.85rem; color: #94a3b8; line-height: 1.6; margin-bottom: 0.75rem;">
      Bluefin operates as an atomic, image-based OS. You can replicate the exact dashboard BDD verification checks locally using the following steps:
    </p>
    <ol style="margin: 0; padding-left: 1.25rem; color: #64748b; font-size: 0.85rem; line-height: 1.7;">
      <li><strong>Verify Cluster Access:</strong> Run <code>just list-vms</code> to confirm connection and schedule availability on ghost control plane.</li>
      <li><strong>Initialize Local SSH Credentials:</strong> Execute <code>just setup-ssh-secret</code> to build the ed25519 key-pair used by workflow pods to ssh into the test VMs.</li>
      <li><strong>Prepare Golden Disk:</strong> Run <code>just ensure-disk testing</code> or <code>just ensure-disk lts-testing</code> to build the VM disk container.</li>
      <li><strong>Submit Test Suite:</strong> Run <code>just run-tests-tag testing</code> to provision the ephemeral VM and watch the live test logs.</li>
    </ol>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  DATA INTEGRITY DISCLOSURE                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <h2 class="section-title">Data Integrity Posture</h2>
  <div class="integrity-panel">
    <h4>Collector-derived contract · v1</h4>
    <div class="stat-dl" style="margin-bottom: 1rem;">
      <div class="stat-dl-item">
        <dt>Generated at</dt>
        <dd style="font-size: 0.9rem;">{formatUtc(contract._meta.generated_at)}</dd>
      </div>
      <div class="stat-dl-item">
        <dt>Status</dt>
        <dd style="font-size: 0.9rem; color: #fbbf24;">{contract._meta.status}</dd>
      </div>
    </div>
    <ul class="integrity-list">
      <li><strong>Evidence-backed authenticity:</strong> Every pass rate, scenario count, and failure name is collected from real BDD test execution logs in the homelab and written into <code>docs/results/</code>.</li>
      <li><strong>No synthetic data:</strong> Gaps and pending/missing runs stay explicitly labeled as <code>unavailable</code> with their exact collector reason instead of being filled with mock or interpolated statistics.</li>
      <li><strong>Lanes and Suites:</strong> Out of {rows.length} total matrix cells (covering {variantOrder.length} variants across {suiteOrder.length} test suites), {availableRows.length} are available with completed runs, and {unavailableRows.length} stay marked as awaiting results.</li>
      <li><strong>History tracking:</strong> Historical trend lines show up to 10 previous runs per cell, allowing change-point and regression detection across active development branches.</li>
    </ul>
    <a href={`${baseUrl}data/tests-matrix.json`} style="margin-top: 1rem; display: inline-block; font-size: 0.85rem; color: #38bdf8;">Open raw dataset ↗</a>
  </div>
</SiteLayout>
