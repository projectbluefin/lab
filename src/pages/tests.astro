---
import { existsSync, readFileSync } from 'node:fs';
import path from 'node:path';

import TestsCharts from '../components/TestsCharts.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import testsMatrix from '../../docs/data/tests-matrix.json';

import KPIGrid from '../components/tests/KPIGrid.astro';
import SuiteMatrix from '../components/tests/SuiteMatrix.astro';
import TestEvidenceCard from '../components/tests/TestEvidenceCard.astro';
import RunbookSection from '../components/tests/RunbookSection.astro';
import EvidenceGallery from '../components/tests/EvidenceGallery.astro';

interface SummaryMetric {
  id: string;
  label: string;
  value: number;
  unit: string;
  state: string;
  state_reason: string | null;
}

interface MatrixHistoryPoint {
  run_date: string;
  workflow_name: string | null;
  status: string;
  scenarios: number;
  failed: number;
}

interface MatrixRowDetails {
  variant: string;
  suite: string;
  last_run: string | null;
  workflow_name: string | null;
  status: string;
  scenarios: number;
  failed: number;
  failed_scenarios?: string[];
  screenshot_url?: string | null;
  history: MatrixHistoryPoint[];
}

interface MatrixRow {
  id: string;
  variant: string;
  branch: string;
  suite: string;
  result_status: string;
  last_run: string | null;
  workflow_name: string | null;
  scenarios_total: number;
  scenarios_failed: number;
  pass_rate: number | null;
  history_points: number;
  results_path: string;
  screenshot_path: string | null;
  screenshot_url: string | null;
  state: string;
  state_reason: string | null;
  source_url: string;
  collected_at: string;
  derivation: string;
  details: MatrixRowDetails | null;
}

type MatrixSourceRow = Omit<MatrixRow, 'details'>;

interface MatrixContract {
  _meta: {
    status: string;
    generated_at: string;
  };
  summary_metrics: SummaryMetric[];
  dimensions: {
    variants: string[];
    suites: string[];
  };
  rows: MatrixSourceRow[];
}

const contract = testsMatrix as unknown as MatrixContract;
const baseUrl = import.meta.env.BASE_URL;

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

const loadRowDetails = (resultsPath: string) => {
  const resultFile = path.join(process.cwd(), 'docs', resultsPath);
  if (!existsSync(resultFile)) {
    return null;
  }

  return JSON.parse(readFileSync(resultFile, 'utf8')) as MatrixRowDetails;
};

const rows = contract.rows
  .map((row) => ({
    ...row,
    details: loadRowDetails(row.results_path),
  }) satisfies MatrixRow)
  .sort((left, right) => left.variant.localeCompare(right.variant) || left.suite.localeCompare(right.suite));

const summaryMetrics = contract.summary_metrics;
const availableRows = rows.filter((row) => row.state === 'available');
const unavailableRows = rows.filter((row) => row.state !== 'available');
const suiteOrder = contract.dimensions.suites;
const variantOrder = contract.dimensions.variants;

// Science-grade KPI computations
const totalScenarios = availableRows.reduce((sum, row) => sum + row.scenarios_total, 0);
const totalFailed = availableRows.reduce((sum, row) => sum + row.scenarios_failed, 0);
const globalPassRate = totalScenarios > 0 ? Number((((totalScenarios - totalFailed) / totalScenarios) * 100).toFixed(2)) : null;

const rowLookup = new Map(rows.map((row) => [`${row.variant}:${row.suite}`, row]));
const matrix = variantOrder.map((variant) => ({
  variant,
  cells: suiteOrder.map((suite) => rowLookup.get(`${variant}:${suite}`) ?? null),
}));

// Rows with screenshots for the visual gallery section
const screenshotRows = rows.filter((row) => row.screenshot_path && existsSync(path.join(process.cwd(), 'docs', row.screenshot_path)));

const workflowHref = (workflowName: string | null) =>
  workflowName ? `http://192.168.1.102:32746/workflows/argo/${encodeURIComponent(workflowName)}` : null;

const detailPassRate = (scenarios: number, failed: number) =>
  scenarios > 0 ? Number((((scenarios - failed) / scenarios) * 100).toFixed(2)) : null;

const chartPayload = {
  generatedAt: contract._meta.generated_at,
  status: contract._meta.status,
  suites: suiteOrder,
  variants: variantOrder,
  rows: rows.map((row) => ({
    id: row.id,
    variant: row.variant,
    suite: row.suite,
    pass_rate: row.pass_rate,
    scenarios_total: row.scenarios_total,
    scenarios_failed: row.scenarios_failed,
    state: row.state,
    state_reason: row.state_reason,
    details: row.details
      ? {
          history: row.details.history,
          failed_scenarios: row.details.failed_scenarios ?? [],
        }
      : null,
  })),
};
---

<SiteLayout
  title="Tests"
  description="Deep tests matrix page for image and application-related suites, with evidence links and ECharts views."
  current="tests"
>
  <style>
    /* ── Dashboard header ─────────────────────────────────────── */
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    /* ── Section titles ──────────────────────────────────────── */
    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }



    /* ── Integrity panel / Explainer ────────────────────────── */
    .integrity-panel {
      background: rgba(15, 23, 42, 0.35);
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 16px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 2rem;
    }
    .integrity-panel h4 {
      font-size: 0.85rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin: 0 0 0.75rem 0;
    }
    .integrity-list {
      margin: 0;
      padding-left: 1.25rem;
      color: #64748b;
      font-size: 0.85rem;
      line-height: 1.7;
    }
    .integrity-list li + li { margin-top: 0.25rem; }
    .integrity-list strong { color: #cbd5e1; }

    .stat-dl {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .stat-dl-item {
      background: rgba(30,41,59,0.3);
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 12px;
      padding: 0.85rem 1rem;
    }
    .stat-dl-item dt { font-size: 0.75rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
    .stat-dl-item dd { font-size: 1.35rem; font-weight: 800; color: #f8fafc; margin: 0.2rem 0 0 0; }

    /* ── Hidden anchor for legacy tests ─────────────────────── */
    .legacy-hidden { display: none !important; }

    /* ── Screenshot visual evidence gallery ─────────────────── */
    .screenshot-gallery {
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
    }
    .screenshot-gallery h4 {
      font-size: 0.82rem;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin: 0 0 0.75rem 0;
    }
    .screenshot-card {
      display: inline-flex;
      flex-direction: column;
      gap: 0.5rem;
      max-width: 520px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.5);
      transition: border-color 0.2s;
    }
    .screenshot-card:hover {
      border-color: rgba(56, 189, 248, 0.35);
    }
    .screenshot-link {
      position: relative;
      display: block;
      text-decoration: none;
    }
    .screenshot-img {
      display: block;
      width: 100%;
      max-height: 320px;
      object-fit: cover;
      object-position: top center;
    }
    .screenshot-overlay {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.85rem;
      font-weight: 700;
      color: rgba(248, 250, 252, 0);
      transition: all 0.2s;
    }
    .screenshot-link:hover .screenshot-overlay {
      background: rgba(15, 23, 42, 0.55);
      color: #f8fafc;
    }
    .screenshot-caption {
      padding: 0.5rem 0.75rem;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    /* ── Educational 16:9 Screenshot Placeholder ── */
    .screenshot-placeholder {
      width: 100%;
      max-width: 520px;
      aspect-ratio: 16 / 9;
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.4) 0%, rgba(15, 23, 42, 0.8) 100%);
      border: 1px dashed rgba(255, 255, 255, 0.12);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      text-align: center;
      box-sizing: border-box;
      transition: all 0.2s ease-in-out;
    }
    .screenshot-placeholder:hover {
      border-color: rgba(56, 189, 248, 0.4);
      background: linear-gradient(135deg, rgba(30, 41, 59, 0.5) 0%, rgba(15, 23, 42, 0.9) 100%);
    }
    .screenshot-placeholder__content {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }
    .placeholder-icon {
      color: #64748b;
      margin-bottom: 0.25rem;
    }
    .screenshot-placeholder h5 {
      margin: 0;
      font-size: 0.95rem;
      font-weight: 700;
      color: #cbd5e1;
    }
    .screenshot-placeholder p {
      margin: 0;
      font-size: 0.78rem;
      color: #64748b;
      line-height: 1.5;
      max-width: 420px;
    }
    .placeholder-meta {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      font-size: 0.72rem;
      color: #475569;
      margin-top: 0.5rem;
    }
    .placeholder-meta code {
      background: rgba(0, 0, 0, 0.3);
      padding: 0.1rem 0.3rem;
      border-radius: 4px;
      color: #38bdf8;
    }

    /* ── Detail toggle controls ──────────────────────────────── */
    .detail-toggle-group {
      display: flex;
      gap: 0.5rem;
      margin-right: 0.5rem;
    }
    .control-btn {
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.2);
      color: #38bdf8;
      padding: 0.35rem 0.75rem;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease-in-out;
    }
    .control-btn:hover {
      background: rgba(56, 189, 248, 0.2);
      border-color: rgba(56, 189, 248, 0.4);
      color: #f8fafc;
    }
  </style>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  HEADER                                                     -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <div class="dashboard-header">
    <h1>Tests Matrix & Evidence</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(contract._meta.generated_at)}</span>
      <span>Source: projectbluefin test results</span>
      <span>Status: <span style="color: #fbbf24;">{contract._meta.status}</span></span>
      <a href={`${baseUrl}data/tests-matrix.json`}>Raw dataset ↗</a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  KPI SCORECARDS                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <h2 class="section-title">Tests at a Glance</h2>
  <KPIGrid
    totalCells={rows.length}
    availableCount={availableRows.length}
    unavailableCount={unavailableRows.length}
    globalPassRate={globalPassRate}
    totalScenarios={totalScenarios}
    summaryMetrics={summaryMetrics}
    status={contract._meta.status}
  />

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  CHARTS SECTION                                             -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <TestsCharts payload={chartPayload} />

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  VISUAL EVIDENCE GALLERY                                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <EvidenceGallery screenshotRows={screenshotRows} />

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  SUITE BY VARIANT MATRIX                                    -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="status-card">
    <div class="section-heading">
      <div>
        <p class="status-card__eyebrow">Matrix</p>
        <h2>Suite by variant matrix</h2>
        <p>
          Every published matrix cell stays visible. Available rows link to detail cards; unpublished or incomplete rows stay marked as unavailable with the collector reason.
        </p>
      </div>
    </div>
    <SuiteMatrix matrix={matrix} suiteOrder={suiteOrder} />
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  PER-ROW EVIDENCE AND HISTORY                               -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <section class="status-card">
    <div class="section-heading">
      <div>
        <p class="status-card__eyebrow">Details</p>
        <h2>Per-row evidence and history</h2>
        <p>
          Detail cards join the matrix with linked result JSON so the page can show failed scenarios, run history, screenshots, and workflow identifiers when they exist.
        </p>
      </div>
      <div class="section-heading__meta" style="align-items: center;">
        <div class="detail-toggle-group">
          <button id="btn-expand-all" class="control-btn">Expand All</button>
          <button id="btn-collapse-all" class="control-btn">Collapse All</button>
        </div>
        <span>{availableRows.length} available</span>
        <span>{unavailableRows.length} unavailable</span>
        <span>{contract._meta.generated_at}</span>
      </div>
    </div>

    <div class="detail-stack">
      {rows.map((row) => (
        <TestEvidenceCard
          row={row}
          workflowHref={workflowHref}
          detailPassRate={detailPassRate}
        />
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  TRIAGE & RUNBOOK SECTION                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <h2 class="section-title">Triage & Local Execution Runbook</h2>
  <RunbookSection />

  <!-- ═══════════════════════════════════════════════════════════ -->
  <!--  DATA INTEGRITY DISCLOSURE                                   -->
  <!-- ═══════════════════════════════════════════════════════════ -->
  <h2 class="section-title">Data Integrity Posture</h2>
  <div class="integrity-panel">
    <h4>Collector-derived contract · v1</h4>
    <div class="stat-dl" style="margin-bottom: 1rem;">
      <div class="stat-dl-item">
        <dt>Generated at</dt>
        <dd style="font-size: 0.9rem;">{formatUtc(contract._meta.generated_at)}</dd>
      </div>
      <div class="stat-dl-item">
        <dt>Status</dt>
        <dd style="font-size: 0.9rem; color: #fbbf24;">{contract._meta.status}</dd>
      </div>
    </div>
    <ul class="integrity-list">
      <li><strong>Evidence-backed authenticity:</strong> Every pass rate, scenario count, and failure name is collected from real BDD test execution logs in the homelab and written into <code>docs/results/</code>.</li>
      <li><strong>No synthetic data:</strong> Gaps and pending/missing runs stay explicitly labeled as <code>unavailable</code> with their exact collector reason instead of being filled with mock or interpolated statistics.</li>
      <li><strong>Lanes and Suites:</strong> Out of {rows.length} total matrix cells (covering {variantOrder.length} variants across {suiteOrder.length} test suites), {availableRows.length} are available with completed runs, and {unavailableRows.length} stay marked as awaiting results.</li>
      <li><strong>History tracking:</strong> Historical trend lines show up to 10 previous runs per cell, allowing change-point and regression detection across active development branches.</li>
    </ul>
    <a href={`${baseUrl}data/tests-matrix.json`} style="margin-top: 1rem; display: inline-block; font-size: 0.85rem; color: #38bdf8;">Open raw dataset ↗</a>
  </div>

  <script>
    // Expand All / Collapse All details
    const btnExpandAll = document.getElementById('btn-expand-all');
    const btnCollapseAll = document.getElementById('btn-collapse-all');
    const detailElements = document.querySelectorAll('details.detail-card');

    btnExpandAll?.addEventListener('click', () => {
      detailElements.forEach((detail) => {
        detail.setAttribute('open', '');
      });
    });

    btnCollapseAll?.addEventListener('click', () => {
      detailElements.forEach((detail) => {
        detail.removeAttribute('open');
      });
    });

    // Scoped search filter for failed scenarios inside each card
    const failureSearchInputs = document.querySelectorAll('.failure-search-input');
    failureSearchInputs.forEach((inputEl) => {
      inputEl.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const query = input.value.toLowerCase().trim();
        const cardId = input.getAttribute('data-card-id');
        const listContainer = document.querySelector(`[data-failures-list="${cardId}"]`);
        if (!listContainer) return;
        
        const rows = listContainer.querySelectorAll('.failure-row');
        rows.forEach((rowEl) => {
          const row = rowEl as HTMLElement;
          const text = row.getAttribute('data-search-text') || '';
          if (text.includes(query)) {
            row.style.display = '';
          } else {
            row.style.display = 'none';
          }
        });
      });
    });

    // Event delegation for copying commands with toast feedback
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.btn-copy-command');
      if (!btn) return;
      
      const command = btn.getAttribute('data-command');
      if (!command) return;
      
      navigator.clipboard.writeText(command).then(() => {
        let toast = document.getElementById('toast-feedback');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'toast-feedback';
          toast.className = 'toast-notification';
          document.body.appendChild(toast);
        }
        
        toast.textContent = 'Behave command copied!';
        toast.classList.add('show');
        
        setTimeout(() => {
          toast?.classList.remove('show');
        }, 2000);
      });
    });
  </script>
</SiteLayout>
