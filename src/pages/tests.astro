---
import { existsSync, readFileSync } from 'node:fs';
import path from 'node:path';

import TestsCharts from '../components/TestsCharts.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import testsMatrix from '../../docs/data/tests-matrix.json';
import releaseVerdict from '../../docs/data/release-verdict.json';

import LaneVerdictStrip from '../components/tests/LaneVerdictStrip.astro';
import KPIGrid from '../components/tests/KPIGrid.astro';
import SuiteMatrix from '../components/tests/SuiteMatrix.astro';
import TestEvidenceCard from '../components/tests/TestEvidenceCard.astro';
import RunbookSection from '../components/tests/RunbookSection.astro';
import QAExplainer from '../components/tests/QAExplainer.astro';

interface SummaryMetric {
  id: string;
  label: string;
  value: number;
  unit: string;
  state: string;
  state_reason: string | null;
}

interface MatrixHistoryPoint {
  run_date: string;
  workflow_name: string | null;
  status: string;
  scenarios: number;
  failed: number;
}

interface MatrixRowDetails {
  variant: string;
  suite: string;
  last_run: string | null;
  workflow_name: string | null;
  status: string;
  scenarios: number;
  failed: number;
  failed_scenarios?: string[];
  screenshot_url?: string | null;
  history: MatrixHistoryPoint[];
}

interface MatrixRow {
  id: string;
  variant: string;
  branch: string;
  suite: string;
  role: string;
  result_status: string;
  last_run: string | null;
  workflow_name: string | null;
  scenarios_total: number;
  scenarios_failed: number;
  pass_rate: number | null;
  history_points: number;
  results_path: string | null;
  screenshot_path: string | null;
  screenshot_url: string | null;
  state: string;
  state_reason: string | null;
  enrollment_issue_url: string | null;
  flake_flips: number;
  runs_recorded: number;
  source_url: string;
  collected_at: string;
  derivation: string;
  details: MatrixRowDetails | null;
}

interface MatrixContract {
  schema_version: string;
  _meta: {
    status: string;
    generated_at: string;
  };
  summary_metrics: SummaryMetric[];
  suite_roles: Record<string, string>;
  dimensions: {
    variants: string[];
    branches: string[];
    suites: string[];
  };
  rows: MatrixRow[];
}

interface TestRun {
  recorded_at: string;
  variant: string;
  branch: string;
  suite: string;
  role: string;
  workflow_name: string;
  status: 'passed' | 'failed';
  scenarios_total: number;
  scenarios_failed: number;
  failed_scenarios: string[];
  digest: string | null;
}

interface ReleaseVerdictHistoryPoint {
  recorded_at: string;
  lane: string;
  digest: string | null;
  verdict: string;
  build: string;
  qa: string;
  signature: string;
}

interface ReleaseVerdictRow {
  id: string;
  lane: string;
  variant: string;
  branch: string;
  image_ref: string;
  digest: string | null;
  verdict: 'good' | 'bad' | 'pending';
  build: {
    status: string;
    reason: string | null;
    run_url?: string | null;
    finished_at?: string | null;
  };
  qa: {
    status: string;
    reason: string | null;
    last_run: string | null;
    lab_sourced: boolean;
    informational: {
      status: string;
      reason: string | null;
      rows: Array<{
        id: string;
        variant: string;
        branch: string;
        suite: string;
        role: string;
        result_status: string;
        workflow_name: string | null;
      }>;
    };
  };
  signature: {
    status: string;
    reason: string | null;
    method?: string;
  };
  source_url: string;
}

const contract = testsMatrix as unknown as MatrixContract;
const verdictContract = releaseVerdict as unknown as {
  _meta: { generated_at: string; status: string };
  summary_metrics: SummaryMetric[];
  rows: ReleaseVerdictRow[];
};
const baseUrl = import.meta.env.BASE_URL;

const readNdjson = <T,>(filePath: string): T[] => {
  const fullPath = path.join(process.cwd(), filePath);
  if (!existsSync(fullPath)) return [];
  return readFileSync(fullPath, 'utf8')
    .split('\n')
    .map((line) => line.trim())
    .filter(Boolean)
    .map((line) => {
      try {
        return JSON.parse(line) as T;
      } catch {
        return null;
      }
    })
    .filter((item): item is T => item !== null);
};

const testRuns = readNdjson<TestRun>('docs/data/history/test-runs.ndjson');
const releaseVerdictHistory = readNdjson<ReleaseVerdictHistoryPoint>('docs/data/history/release-verdict.ndjson');

const formatUtc = (value: string | null) =>
  value
    ? new Date(value).toLocaleString('en-US', {
        dateStyle: 'medium',
        timeStyle: 'short',
        timeZone: 'UTC',
      }) + ' UTC'
    : 'Never';

const loadRowDetails = (resultsPath: string | null) => {
  if (!resultsPath) return null;
  const resultFile = path.join(process.cwd(), 'docs', resultsPath);
  if (!existsSync(resultFile)) return null;
  return JSON.parse(readFileSync(resultFile, 'utf8')) as MatrixRowDetails;
};

const rows = contract.rows.map((row) => ({
  ...row,
  details: loadRowDetails(row.results_path),
})) satisfies MatrixRow[];

const suiteOrder = contract.dimensions.suites;
const variantOrder = contract.dimensions.variants;

const rowLookup = new Map<string, MatrixRow>();
for (const row of rows) {
  const key = `${row.variant}:${row.suite}`;
  const existing = rowLookup.get(key);
  if (!existing || row.branch === 'testing') {
    rowLookup.set(key, row);
  }
}

const matrix = variantOrder.map((variant) => ({
  variant,
  cells: suiteOrder.map((suite) => rowLookup.get(`${variant}:${suite}`) ?? null),
}));

const availableRows = rows.filter((row) => row.state === 'available');
const unavailableRows = rows.filter((row) => row.state !== 'available');

const passRateForRows = (subset: MatrixRow[]) => {
  const total = subset.reduce((sum, row) => sum + row.scenarios_total, 0);
  const failed = subset.reduce((sum, row) => sum + row.scenarios_failed, 0);
  return total > 0 ? Number((((total - failed) / total) * 100).toFixed(2)) : null;
};

const gatingRows = availableRows.filter((row) => row.role === 'gate');
const infoRows = availableRows.filter((row) => row.role === 'info');
const gatingPassRate = passRateForRows(gatingRows);
const infoPassRate = passRateForRows(infoRows);
const flakyRows = rows.filter((row) => Number(row.flake_flips) >= 1).length;

const lanesGood = verdictContract.rows.filter((r) => r.verdict === 'good').length;
const lanesTotal = verdictContract.rows.length;

const workflowHref = (workflowName: string | null) =>
  workflowName ? `http://192.168.1.102:32746/workflows/argo/${encodeURIComponent(workflowName)}` : null;

const detailPassRate = (scenarios: number, failed: number) =>
  scenarios > 0 ? Number((((scenarios - failed) / scenarios) * 100).toFixed(2)) : null;

const chartPayload = {
  generatedAt: contract._meta.generated_at,
  status: contract._meta.status,
  suites: suiteOrder,
  variants: variantOrder,
  rows: rows.map((row) => ({
    id: row.id,
    variant: row.variant,
    branch: row.branch,
    suite: row.suite,
    role: row.role,
    pass_rate: row.pass_rate,
    scenarios_total: row.scenarios_total,
    scenarios_failed: row.scenarios_failed,
    state: row.state,
    state_reason: row.state_reason,
    enrollment_issue_url: row.enrollment_issue_url,
    flake_flips: row.flake_flips,
    runs_recorded: row.runs_recorded,
    details: row.details
      ? {
          history: row.details.history,
          failed_scenarios: row.details.failed_scenarios ?? [],
        }
      : null,
  })),
  testRuns,
  releaseVerdictHistory,
};

const releaseVerdictSource = `${baseUrl}data/release-verdict.json`;
const matrixSource = `${baseUrl}data/tests-matrix.json`;
const historySource = `${baseUrl}data/history/test-runs.ndjson`;
---

<SiteLayout
  title="Tests"
  description="Deep tests matrix page for image and application-related suites, with evidence links and ECharts views."
  current="tests"
>
  <style>
    .dashboard-header {
      margin-bottom: 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.5rem;
    }
    .dashboard-header h1 {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.04em;
      margin: 0 0 0.5rem 0;
      background: linear-gradient(135deg, #f8fafc 30%, #94a3b8 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .meta-bar {
      font-size: 0.85rem;
      color: #94a3b8;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      align-items: center;
    }
    .meta-bar a { color: #38bdf8; text-decoration: none; }
    .meta-bar a:hover { text-decoration: underline; }

    .section-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #cbd5e1;
      margin: 2.5rem 0 1rem 0;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      border-left: 3px solid #38bdf8;
      padding-left: 10px;
    }

    .detail-toggle-group {
      display: flex;
      gap: 0.5rem;
      margin-right: 0.5rem;
    }
    .control-btn {
      background: rgba(56, 189, 248, 0.1);
      border: 1px solid rgba(56, 189, 248, 0.2);
      color: #38bdf8;
      padding: 0.35rem 0.75rem;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease-in-out;
    }
    .control-btn:hover {
      background: rgba(56, 189, 248, 0.2);
      border-color: rgba(56, 189, 248, 0.4);
      color: #f8fafc;
    }

    .provenance-footer {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: space-between;
      align-items: center;
      font-size: 0.78rem;
      color: #64748b;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 1rem;
      margin-top: 2rem;
    }
  </style>

  <div class="dashboard-header">
    <h1>Tests Matrix & Evidence</h1>
    <div class="meta-bar">
      <span>Updated {formatUtc(contract._meta.generated_at)}</span>
      <span>Contract: v{contract.schema_version}</span>
      <span>Status: <span style="color: #fbbf24;">{contract._meta.status}</span></span>
      <a href={matrixSource}>Raw dataset</a>
    </div>
  </div>

  <LaneVerdictStrip lanes={verdictContract.rows} />

  <h2 class="section-title">Tests at a glance</h2>
  <KPIGrid
    lanesGood={lanesGood}
    lanesTotal={lanesTotal}
    gatingPassRate={gatingPassRate}
    infoPassRate={infoPassRate}
    flakyRows={flakyRows}
    releaseVerdictSource={releaseVerdictSource}
    matrixSource={matrixSource}
    historySource={historySource}
  />

  <TestsCharts payload={chartPayload} />

  <section class="status-card">
    <div class="section-heading">
      <div>
        <p class="status-card__eyebrow">Matrix</p>
        <h2>Suite by variant matrix</h2>
        <p>
          Every published matrix cell stays visible. Grey cells are unavailable; cells with an enrollment issue link to the tracking issue. Click a cell to jump to its evidence card.
        </p>
      </div>
    </div>
    <SuiteMatrix matrix={matrix} suiteOrder={suiteOrder} suiteRoles={contract.suite_roles} />
  </section>

  <section class="status-card">
    <div class="section-heading">
      <div>
        <p class="status-card__eyebrow">Details</p>
        <h2>Per-row evidence and history</h2>
        <p>
          Evidence cards join the matrix with linked result JSON so the page can show failed scenarios, run history, screenshots, and workflow identifiers when they exist.
        </p>
      </div>
      <div class="section-heading__meta" style="align-items: center;">
        <div class="detail-toggle-group">
          <button id="btn-expand-all" class="control-btn">Expand All</button>
          <button id="btn-collapse-all" class="control-btn">Collapse All</button>
        </div>
        <span>{availableRows.length} available</span>
        <span>{unavailableRows.length} unavailable</span>
      </div>
    </div>

    <div class="detail-stack">
      {rows.map((row) => (
        <TestEvidenceCard
          row={row}
          workflowHref={workflowHref}
          detailPassRate={detailPassRate}
        />
      ))}
    </div>
  </section>

  <h2 class="section-title">Triage & local execution runbook</h2>
  <RunbookSection />

  <h2 class="section-title">About the test split</h2>
  <QAExplainer />

  <div class="provenance-footer">
    <span>Generated at {formatUtc(contract._meta.generated_at)} · {contract._meta.status}</span>
    <a href={matrixSource}>tests-matrix.json</a>
  </div>

  <script>
    const btnExpandAll = document.getElementById('btn-expand-all');
    const btnCollapseAll = document.getElementById('btn-collapse-all');
    const detailElements = document.querySelectorAll('details.detail-card');

    btnExpandAll?.addEventListener('click', () => {
      detailElements.forEach((detail) => {
        detail.setAttribute('open', '');
      });
    });

    btnCollapseAll?.addEventListener('click', () => {
      detailElements.forEach((detail) => {
        detail.removeAttribute('open');
      });
    });

    const failureSearchInputs = document.querySelectorAll('.failure-search-input');
    failureSearchInputs.forEach((inputEl) => {
      inputEl.addEventListener('input', (e) => {
        const input = e.target as HTMLInputElement;
        const query = input.value.toLowerCase().trim();
        const cardId = input.getAttribute('data-card-id');
        const listContainer = document.querySelector(`[data-failures-list="${cardId}"]`);
        if (!listContainer) return;

        const rows = listContainer.querySelectorAll('.failure-row');
        rows.forEach((rowEl) => {
          const row = rowEl as HTMLElement;
          const text = row.getAttribute('data-search-text') || '';
          row.style.display = text.includes(query) ? '' : 'none';
        });
      });
    });

    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.btn-copy-command');
      if (!btn) return;

      const command = btn.getAttribute('data-command');
      if (!command) return;

      navigator.clipboard.writeText(command).then(() => {
        let toast = document.getElementById('toast-feedback');
        if (!toast) {
          toast = document.createElement('div');
          toast.id = 'toast-feedback';
          toast.className = 'toast-notification';
          document.body.appendChild(toast);
        }

        toast.textContent = 'Behave command copied!';
        toast.classList.add('show');

        setTimeout(() => {
          toast?.classList.remove('show');
        }, 2000);
      });
    });
  </script>
</SiteLayout>
