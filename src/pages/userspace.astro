    }

    @media (max-width: 1200px) {
      .registry-horizontal-row {
        grid-template-columns: auto 1fr 1.2fr auto;
      }
      .card-sparklines {
        display: none;
      }
    }

    @media (max-width: 960px) {
      .registry-horizontal-row {
        grid-template-columns: auto 1fr;
        gap: 1.25rem;
      }
      .card-sparklines {
        display: flex;
        grid-column: 1 / -1;
        flex-direction: row;
        border-left: 0;
        padding-left: 0;
        gap: 1.5rem;
