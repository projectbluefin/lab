    }
    .registry-info p {
      font-size: 0.85rem;
      color: #94a3b8;
      margin: 0;
      line-height: 1.45;
    }
    .registry-element-badge {
      font-family: ui-monospace, monospace;
      font-size: 0.72rem;
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid rgba(56, 189, 248, 0.15);
      color: #38bdf8;
