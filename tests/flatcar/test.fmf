/boot:
    summary: Flatcar boot smoke test
    tier: 1
    framework: pytest
    test: pytest -q test_flatcar_boot.py

/knuckle:
    summary: Knuckle installer integration
    tier: 2
    framework: pytest
    test: pytest -q test_flatcar_knuckle.py
    environment:
        KNUCKLE_BINARY: /usr/local/bin/knuckle
