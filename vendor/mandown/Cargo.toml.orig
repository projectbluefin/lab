[package]
name = "mandown"
version = "1.1.0"
authors = ["Kornel <kornel@geekhood.net>"]
edition = "2021"
description = "Markdown to groff (man page) converter"
license = "Apache-2.0 OR MIT"
include = ["/Cargo.toml", "README.md", "/src/*.rs"]
readme = "README.md"
homepage = "https://lib.rs/mandown"
keywords = ["markdown", "manpage", "roff", "troff", "groff"]
categories = ["text-processing", "command-line-utilities"]
repository = "https://gitlab.com/kornelski/mandown.git"
rust-version = "1.74"

[dependencies]
pulldown-cmark = "0.13"
deunicode = "1.6.1"

[profile.release]
lto = true
debug = false
opt-level = 3
panic = "abort"

[package.metadata.docs.rs]
targets = ["x86_64-unknown-linux-gnu"]
rustdoc-args = ["--generate-link-to-definition"]
