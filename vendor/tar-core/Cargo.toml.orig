[package]
name = "tar-core"
version = "0.1.0"
edition = "2021"
rust-version = "1.86.0"
license = "MIT OR Apache-2.0"
description = "Sans-IO tar header parsing and building for sync and async runtimes"
keywords = ["tar", "zerocopy", "header", "sans-io", "async"]
categories = ["encoding", "parser-implementations", "no-std"]
repository = "https://github.com/composefs/tar-core"
readme = "README.md"

[features]
default = ["std"]
std = ["zerocopy/std"]

[dependencies]
thiserror = { version = "2.0", default-features = false }
zerocopy = { version = "0.8.0", default-features = false, features = ["derive"] }

[dev-dependencies]
arbitrary = { version = "1", features = ["derive"] }
base64 = "0.22"
kani-verifier = "0.67"
proptest = "1"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
rand = "0.9"
similar-asserts = "1"
tar = "0.4"
tar-core-testutil = { path = "testutil" }
tempfile = "3"
xshell = "0.2"


[lints.rust]
missing_docs = "warn"
missing_debug_implementations = "warn"
unsafe_code = "forbid"
unexpected_cfgs = { level = "warn", check-cfg = ['cfg(kani)'] }

[workspace]
members = [".", "testutil"]
exclude = ["fuzz"]
